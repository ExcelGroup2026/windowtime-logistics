hai';\n  font-style: normal;\n  font-weight: 500;\n  font-display: swap;\n  src: url(\"418eb21c-0b1e-42b7-8bbf-7142593b55d3\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 500;\n  font-display: swap;\n  src: url(\"de0533e9-6dc0-4b63-a68f-4b872f285a0c\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* cyrillic-ext */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"bed9205a-dd6d-41da-802b-759f11f69df1\") format('woff2');\n  unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;\n}\n/* thai */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"5c33a2fe-c077-4261-9973-eb1e573f578c\") format('woff2');\n  unicode-range: U+02D7, U+0303, U+0331, U+0E01-0E5B, U+200C-200D, U+25CC;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"55632a32-f6f3-47a5-a51e-e8847694ad9e\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"2f3e07a1-dd82-4b86-a540-bee1a7e0c465\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* cyrillic-ext */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"5bcba0ff-7941-4bc7-b794-6431811fb595\") format('woff2');\n  unicode-range: U+0460-052F, U+1C80-1C8A, U+20B4, U+2DE0-2DFF, U+A640-A69F, U+FE2E-FE2F;\n}\n/* thai */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"fa866e19-94fa-4be0-aa43-b13e5d4f8356\") format('woff2');\n  unicode-range: U+02D7, U+0303, U+0331, U+0E01-0E5B, U+200C-200D, U+25CC;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"70f82d3a-5f84-45d4-9290-7da72fa6e788\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'IBM Plex Sans Thai';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"6f4e18bd-da70-4f2a-9ebe-6d19804552d7\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>\n*{box-sizing:border-box}\nbody{margin:0;font-family:'IBM Plex Sans Thai',sans-serif;color:#16202e;background:#eef1f5;-webkit-font-smoothing:antialiased}\na{color:#2456c8;text-decoration:none}a:hover{color:#1a44a0}\ninput,select,textarea,button{font-family:inherit}\n.mono{font-family:'IBM Plex Mono',ui-monospace,monospace;font-feature-settings:\"tnum\"}\n.f1{flex:1}\n/* ---------- AUTH ---------- */\n.auth{display:grid;grid-template-columns:1.05fr 1fr;height:100vh;overflow:hidden}\n.authbrand{background:linear-gradient(160deg,#0f1e35,#173163 70%,#1c4187);color:#fff;padding:56px 60px;display:flex;flex-direction:column;position:relative;overflow:hidden}\n.authbrand::after{content:'';position:absolute;right:-120px;bottom:-120px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(75,140,255,.35),transparent 70%)}\n.abrow{display:flex;align-items:center;gap:12px}\n.ablogo{width:46px;height:46px;border-radius:12px;background:linear-gradient(150deg,#2f7cf6,#1b46b8);display:flex;align-items:center;justify-content:center}\n.abname{font-size:22px;font-weight:700}\n.abtag{font-size:13px;color:#9fb2d6}\n.ahead{font-size:38px;font-weight:700;line-height:1.2;margin-top:auto;letter-spacing:-.5px}\n.asub{font-size:15px;color:#aebfdd;margin-top:16px;line-height:1.6;max-width:400px}\n.astats{display:flex;gap:34px;margin-top:38px}\n.astat .n{font-size:30px;font-weight:700}\n.astat .l{font-size:12.5px;color:#9fb2d6;margin-top:2px}\n.authform{display:flex;align-items:center;justify-content:center;padding:40px;overflow-y:auto}\n.authcard{width:100%;max-width:392px}\n.at{font-size:25px;font-weight:700;letter-spacing:-.3px}\n.ap{font-size:14px;color:#7c8aa3;margin-top:6px;margin-bottom:26px}\n.field{margin-bottom:15px}\n.lbl{font-size:12.5px;font-weight:600;color:#48566d;display:block;margin-bottom:6px}\n.inp{width:100%;border:1.5px solid #dbe1ea;border-radius:10px;padding:11px 13px;font-size:14px;background:#fff;color:#16202e}\n.inp:focus{outline:none;border-color:#1d64f0;box-shadow:0 0 0 3px rgba(29,100,240,.13)}\n.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px}\n.roles{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px}\n.rolebtn{border:1.5px solid #dbe1ea;background:#fff;border-radius:11px;padding:12px;cursor:pointer;text-align:left;display:flex;gap:10px;align-items:center}\n.rolebtn:hover{border-color:#b9c6dd;background:#f8fafd}\n.rolebtn.on{border-color:#1d64f0;background:#eef4ff}\n.rbic{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}\n.rbt{font-weight:600;font-size:13px;display:block;line-height:1.2}\n.rbs{font-size:11px;color:#8593a8;display:block;margin-top:1px}\n.btn{border:none;border-radius:10px;padding:11px 16px;font-size:14px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:8px}\n.btn-pri{background:#1d64f0;color:#fff}.btn-pri:hover{background:#1550d0}\n.btn-gho{background:#eef2f8;color:#39485f}.btn-gho:hover{background:#e3e9f2}\n.btn-blk{width:100%;margin-top:6px;padding:13px}\n.authlink{text-align:center;margin-top:18px;font-size:13.5px;color:#7c8aa3}\n.divider{display:flex;align-items:center;gap:12px;color:#a7b2c4;font-size:12px;margin:20px 0}\n.divider::before,.divider::after{content:'';height:1px;background:#e4e9f1;flex:1}\n/* ---------- APP SHELL ---------- */\n.app{display:grid;grid-template-columns:236px 1fr;height:100vh;overflow:hidden}\n.side{background:#0e1a2b;color:#c3cde0;display:flex;flex-direction:column;padding:20px 14px;overflow-y:auto}\n.brand{display:flex;align-items:center;gap:10px;padding:4px 8px 16px}\n.logo{width:34px;height:34px;border-radius:9px;background:linear-gradient(150deg,#2f7cf6,#1b46b8);display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0}\n.bname{font-weight:700;font-size:16px;color:#fff;line-height:1.1}\n.bsub{font-size:11px;color:#7d8bab;letter-spacing:.3px}\n.navlab{font-size:10.5px;letter-spacing:1px;color:#5c6b8a;text-transform:uppercase;padding:14px 10px 6px}\n.navlink{display:flex;align-items:center;gap:11px;padding:9px 11px;border-radius:9px;font-size:14px;color:#aab6d0;cursor:pointer;font-weight:500}\n.navlink:hover{background:#182741;color:#e6ecfa}\n.navlink.on{background:#1d64f0;color:#fff}\n.navlink .ic{width:18px;height:18px;flex-shrink:0}\n.sheetbox{margin-top:14px;background:#12223a;border:1px solid #22345a;border-radius:11px;padding:11px 12px}\n.sidefoot{margin-top:auto;border-top:1px solid #1d2c44;padding-top:14px;display:flex;align-items:center;gap:10px}\n.avatar{width:34px;height:34px;border-radius:50%;background:#26406b;color:#cfe0ff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:13px;flex-shrink:0}\n.lgout{margin-left:auto;background:none;border:none;color:#7d8bab;cursor:pointer;padding:6px;border-radius:7px}\n.lgout:hover{background:#182741;color:#e6ecfa}\n.main{overflow-y:auto;position:relative}\n.topbar{position:sticky;top:0;z-index:20;background:#fbfcfe;border-bottom:1px solid #e0e6ef;padding:14px 26px;display:flex;align-items:center;gap:16px}\n.h1{font-size:20px;font-weight:700;letter-spacing:-.2px;line-height:1.15}\n.h1 span{color:#7c8aa3;font-weight:500;font-size:13px;display:block;letter-spacing:0}\n.sync{display:flex;align-items:center;gap:8px;background:#eaf6ee;border:1px solid #c4e6cf;color:#1c7a44;border-radius:20px;padding:6px 12px;font-size:12px;font-weight:600}\n.syncic{width:14px;height:14px;animation:spin 3.5s linear infinite}\n@keyframes spin{to{transform:rotate(360deg)}}\n.userchip{margin-left:auto;display:flex;align-items:center;gap:11px;background:#fff;border:1px solid #e4e9f1;border-radius:30px;padding:5px 6px 5px 14px}\n.uc-name{font-size:13.5px;font-weight:600;line-height:1.15;text-align:right}\n.rolebadge{font-size:10.5px;font-weight:700;padding:2px 8px;border-radius:20px;display:inline-block;margin-top:2px}\n.role-staff{background:#e8f0fe;color:#1d5fd6}\n.role-sup{background:#eae7fd;color:#5b48d6}\n.role-drv{background:#fff2dc;color:#b26b06}\n.role-exec{background:#e6f6ec;color:#0f8a4d}\n.role-ops{background:#d8f3ee;color:#0f766e}\n.uc-av{width:36px;height:36px;border-radius:50%;background:#12233d;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:13px}\n.clock{text-align:right}\n.clocktime{font-size:19px;font-weight:600;letter-spacing:.5px}\n.clockdate{font-size:11.5px;color:#7c8aa3}\n.livedot{display:inline-block;width:8px;height:8px;border-radius:50%;background:#22b562;margin-right:6px;animation:pulse 1.8s infinite}\n@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(34,181,98,.5)}70%{box-shadow:0 0 0 7px rgba(34,181,98,0)}100%{box-shadow:0 0 0 0 rgba(34,181,98,0)}}\n@keyframes blink{50%{opacity:.35}}\n.wrap{padding:22px 26px 44px}\n/* KPI */\n.kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:20px}\n.kpi{background:#fff;border:1px solid #e4e9f1;border-radius:14px;padding:15px 16px}\n.kl{font-size:12.5px;color:#6b7a92;font-weight:500;display:flex;align-items:center;gap:7px}\n.kv{font-size:29px;font-weight:700;letter-spacing:-.5px;margin-top:7px;line-height:1}\n.kv small{font-size:15px;color:#93a0b5;font-weight:600}\n.kt{font-size:11.5px;margin-top:6px;font-weight:600}\n.up{color:#0f9d58}.down{color:#e0562f}.flat{color:#7c8aa3}\n.dot{width:9px;height:9px;border-radius:3px;display:inline-block}\n.grid2{display:grid;grid-template-columns:1fr 322px;gap:18px;align-items:start}\n.card{background:#fff;border:1px solid #e4e9f1;border-radius:14px}\n.mb18{margin-bottom:18px}\n.card-h{padding:15px 18px;border-bottom:1px solid #eef1f6;display:flex;align-items:center;gap:12px}\n.card-t{font-weight:700;font-size:15px}\n.card-t small{color:#93a0b5;font-weight:500;font-size:12px;margin-left:6px}\n.gantt{padding:14px 18px 20px}\n.axis{display:flex;margin-left:78px;border-bottom:1px solid #eef1f6;position:relative;height:18px}\n.tick{flex:1;font-size:10.5px;color:#9aa6bb;text-align:left}\n.track{display:flex;align-items:center;height:38px;position:relative}\n.tname{width:78px;flex-shrink:0;font-size:12px;font-weight:600;color:#55637b}\n.lane{flex:1;position:relative;height:26px;background:#f5f7fb;border-radius:7px}\n.slot{position:absolute;top:0;height:26px;border-radius:7px;display:flex;align-items:center;padding:0 8px;font-size:11px;font-weight:600;color:#fff;cursor:pointer;overflow:hidden;white-space:nowrap;box-shadow:inset 0 0 0 1px rgba(255,255,255,.18)}\n.slot:hover{filter:brightness(1.07);outline:2px solid rgba(29,100,240,.4)}\n.nowwrap{position:relative;margin-left:78px}\n.nowline{position:absolute;top:-2px;bottom:0;width:2px;background:#e0344b;z-index:5}\n.nowline::before{content:'';position:absolute;top:-3px;left:-3px;width:8px;height:8px;border-radius:50%;background:#e0344b}\n.filters{display:flex;gap:8px;margin-left:auto}\n.chip{border:1px solid #dde3ec;background:#fff;border-radius:20px;padding:5px 13px;font-size:12.5px;font-weight:600;color:#5a687f;cursor:pointer}\n.chip:hover{background:#f3f6fb}\n.chip.on{background:#12233d;color:#fff;border-color:#12233d}\n.chip .c{opacity:.55;margin-left:5px}\ntable{width:100%;border-collapse:collapse}\nthead th{text-align:left;font-size:11px;letter-spacing:.4px;text-transform:uppercase;color:#8b98ad;font-weight:600;padding:10px 14px;border-bottom:1px solid #eef1f6;background:#fbfcfe}\ntbody td{padding:11px 14px;border-bottom:1px solid #f1f4f8;font-size:13px;vertical-align:middle}\ntbody tr.clik{cursor:pointer}\ntbody tr.clik:hover{background:#f6f9ff}\ntbody tr.sel{background:#eef4ff}\n.qno{width:30px;height:30px;border-radius:8px;background:#eaf0fb;color:#1d4fbf;font-weight:700;display:flex;align-items:center;justify-content:center;font-size:13px}\n.cust{font-weight:600}\n.subt{color:#8593a8;font-size:11.5px}\n.veh{display:flex;align-items:center;gap:8px}\n.tt{font-size:10px;font-weight:700;padding:2px 6px;border-radius:5px;background:#eef2f8;color:#5a687f}\n.fleet-own{color:#0f7d55;font-weight:600;font-size:11.5px}.fleet-sub{color:#a2650f;font-weight:600;font-size:11.5px}\n.win{font-weight:600}\n.progwrap{display:flex;align-items:center;gap:8px;min-width:150px}\n.progbar{flex:1;height:6px;border-radius:4px;background:#eef1f6;overflow:hidden}\n.progfill{height:100%;border-radius:4px}\n.progpct{font-size:11px;color:#8593a8;width:30px;font-weight:600}\n.badge{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:20px;font-size:11.5px;font-weight:600;white-space:nowrap}\n.bd{width:7px;height:7px;border-radius:50%}\n.ph-sched{background:#eef1f6;color:#64748b}.ph-sched .bd{background:#94a3b8}\n.ph-wait{background:#e8f0fe;color:#1d5fd6}.ph-wait .bd{background:#1d5fd6}\n.ph-active{background:#fff2dc;color:#b26b06}.ph-active .bd{background:#f59e0b;animation:blink 1.3s infinite}\n.ph-transit{background:#ecebfe;color:#5b48d6}.ph-transit .bd{background:#6d5ae0;animation:blink 1.3s infinite}\n.ph-done{background:#e6f6ec;color:#0f8a4d}.ph-done .bd{background:#22b562}\n.ph-issue{background:#fbe0e0;color:#c62b2b}.ph-issue .bd{background:#e0344b}\n.tag{font-size:10.5px;font-weight:700;padding:2px 7px;border-radius:5px;margin-left:6px}\n.tag-ontime{background:#e6f6ec;color:#0f8a4d}\n.tag-lateO{background:#fdeccf;color:#a2650f}\n.tag-lateD{background:#fde3d3;color:#c1461c}\n.tag-issue{background:#fbe0e0;color:#c62b2b}\n.alert{display:flex;gap:11px;padding:13px 16px;border-bottom:1px solid #f1f4f8;cursor:pointer}\n.alert:last-child{border-bottom:none}\n.alert:hover{background:#f8fafd}\n.aic{width:32px;height:32px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center}\n.a-lateO{background:#fdeccf;color:#a2650f}.a-lateD{background:#fde3d3;color:#c1461c}.a-issue{background:#fbe0e0;color:#c62b2b}\n.atitle{font-weight:600;font-size:13px}\n.amsg{font-size:12px;color:#7a8698;margin-top:2px;line-height:1.35}\n/* drawer */\n.scrim{position:fixed;inset:0;background:rgba(15,26,43,.42);z-index:40;display:flex;justify-content:flex-end}\n.drawer{width:430px;max-width:92vw;height:100%;background:#fff;box-shadow:-8px 0 40px rgba(15,26,43,.22);display:flex;flex-direction:column;animation:slidein .22s ease}\n@keyframes slidein{from{transform:translateX(30px);opacity:.4}to{transform:translateX(0);opacity:1}}\n.dh{padding:18px 22px;border-bottom:1px solid #eef1f6;display:flex;align-items:flex-start;gap:12px}\n.dclose{margin-left:auto;width:32px;height:32px;border-radius:8px;background:#f1f4f8;border:none;cursor:pointer;color:#5a687f;font-size:17px;display:flex;align-items:center;justify-content:center}\n.dclose:hover{background:#e6ebf2}\n.dbody{overflow-y:auto;padding:20px 22px;flex:1}\n.metagrid{display:grid;grid-template-columns:1fr 1fr;gap:12px 18px;margin-bottom:20px}\n.mlab{font-size:11px;color:#8b98ad;font-weight:600;text-transform:uppercase;letter-spacing:.3px}\n.mval{font-size:14px;font-weight:600;margin-top:2px}\n.sec{font-size:12px;font-weight:700;color:#55637b;text-transform:uppercase;letter-spacing:.5px;margin:6px 0 12px}\n.tl{position:relative;padding-left:8px}\n.step{display:flex;gap:14px;position:relative;padding-bottom:16px}\n.step:last-child{padding-bottom:0}\n.stline{position:absolute;left:9px;top:20px;bottom:-2px;width:2px;background:#e6ebf2}\n.step.done .stline{background:#22b562}\n.snode{width:20px;height:20px;border-radius:50%;border:2px solid #cdd6e3;background:#fff;flex-shrink:0;z-index:1;display:flex;align-items:center;justify-content:center}\n.step.done .snode{border-color:#22b562;background:#22b562;color:#fff}\n.step.next .snode{border-color:#1d64f0;animation:blink 1.3s infinite}\n.slabel{font-size:13.5px;font-weight:600;line-height:1.2}\n.slabel small{display:block;font-weight:500;color:#93a0b5;font-size:11px}\n.stime{margin-left:auto;text-align:right}\n.stimev{font-size:14px;font-weight:600}\n.stime .pend{color:#b3bccb;font-weight:500;font-size:12px}\n.dfoot{padding:16px 22px;border-top:1px solid #eef1f6;display:flex;gap:10px}\n.note{background:#fff8ec;border:1px solid #f2e2c0;border-radius:10px;padding:11px 13px;font-size:12.5px;color:#7a5f1f;margin-bottom:18px;display:flex;gap:9px}\n/* CALENDAR */\n.calgrid{display:grid;grid-template-columns:1.4fr 1fr;gap:18px;align-items:start}\n.cal{padding:8px 14px 16px}\n.calhead{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-bottom:6px}\n.cah{text-align:center;font-size:11.5px;font-weight:600;color:#8b98ad;padding:6px 0}\n.calbody{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}\n.cell{aspect-ratio:1/.82;border-radius:10px;border:1px solid #eef1f6;padding:7px 8px;cursor:pointer;position:relative;background:#fff}\n.cell:hover{border-color:#c3d0e6;background:#f8fafd}\n.cell.empty{border:none;background:none;cursor:default}\n.cell.on{border-color:#1d64f0;background:#eef4ff;box-shadow:0 0 0 1px #1d64f0}\n.cell.today .cd{background:#1d64f0;color:#fff;border-radius:6px;padding:0 5px}\n.cd{font-size:13px;font-weight:600}\n.ccount{position:absolute;left:8px;bottom:7px;font-size:11px;font-weight:600;color:#1d5fd6;display:flex;align-items:center;gap:4px}\n.ccount .cdot{width:6px;height:6px;border-radius:50%;background:#1d64f0}\n.dsched{padding:6px 4px}\n.dsitem{display:flex;gap:11px;padding:11px 8px;border-bottom:1px solid #f1f4f8;align-items:center}\n.dsitem:last-child{border-bottom:none}\n.route{font-size:12.5px;color:#55637b;display:flex;align-items:center;gap:5px}\n/* FORM PAGE */\n.formgrid{display:grid;grid-template-columns:1.15fr .85fr;gap:18px;align-items:start}\n.formbody{padding:20px 22px}\n.frow{display:grid;grid-template-columns:1fr 1fr;gap:14px}\n.frow3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}\n.seg{display:flex;gap:8px}\n.segbtn{flex:1;border:1.5px solid #dbe1ea;background:#fff;border-radius:9px;padding:10px;font-size:13px;font-weight:600;color:#55637b;cursor:pointer}\n.segbtn.on{border-color:#1d64f0;background:#eef4ff;color:#1d5fd6}\n.dests{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}\n.destchip{background:#eef4ff;color:#1d5fd6;border-radius:8px;padding:6px 10px;font-size:12.5px;font-weight:600;display:flex;align-items:center;gap:7px}\n.destx{cursor:pointer;opacity:.6;font-weight:700}.destx:hover{opacity:1}\n.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f8a4d;color:#fff;padding:12px 20px;border-radius:11px;font-size:14px;font-weight:600;box-shadow:0 8px 30px rgba(15,138,77,.35);z-index:60;display:flex;align-items:center;gap:9px;animation:slidein .25s ease}\n.emptyb{padding:30px;text-align:center;color:#a7b2c4;font-size:13.5px}\n.lockbar{background:#fff4e5;border:1px solid #f2d9a8;color:#8a5a12;border-radius:11px;padding:12px 16px;font-size:13.5px;margin-bottom:16px;display:flex;gap:9px;align-items:center;font-weight:500}\n.lockbar b{color:#8a5a12}\n.locked{opacity:.5;pointer-events:none}\n.cancelbox{padding:16px 22px;border-top:1px solid #eef1f6;background:#fff6f6}\n.cancelbox textarea{resize:vertical;width:100%}\n/* KPI REPORT */\n.kgrid{display:grid;grid-template-columns:1fr 1fr;gap:18px;align-items:start}\n.bars{display:flex;align-items:flex-end;gap:14px;height:190px;padding:20px 20px 8px}\n.barcol{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:8px;height:100%}\n.bar{width:100%;max-width:38px;border-radius:7px 7px 0 0;background:linear-gradient(180deg,#3f82f7,#1d64f0);position:relative}\n.barv{font-size:11.5px;font-weight:700;color:#39485f}\n.barl{font-size:11px;color:#8b98ad}\n.donutwrap{display:flex;align-items:center;gap:24px;padding:22px}\n.donut{width:150px;height:150px;border-radius:50%;flex-shrink:0;position:relative}\n.donut::after{content:'';position:absolute;inset:26px;background:#fff;border-radius:50%}\n.dcenter{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:1}\n.dcv{font-size:26px;font-weight:700}\n.dcl{font-size:11px;color:#8b98ad}\n.legend{flex:1;display:flex;flex-direction:column;gap:12px}\n.lgi{display:flex;align-items:center;gap:10px;font-size:13px}\n.lgsw{width:12px;height:12px;border-radius:4px}\n.lgv{margin-left:auto;font-weight:700}\n.hbars{padding:18px 22px;display:flex;flex-direction:column;gap:16px}\n.hbrow{display:flex;align-items:center;gap:12px}\n.hbname{width:130px;font-size:13px;font-weight:600}\n.hbtrack{flex:1;height:12px;background:#eef1f6;border-radius:7px;overflow:hidden}\n.hbfill{height:100%;border-radius:7px}\n.hbv{width:42px;text-align:right;font-weight:700;font-size:13px}\n/* SUPPLIER cards */\n.supgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}\n.supcard{background:#fff;border:1px solid #e4e9f1;border-radius:14px;padding:18px 20px}\n.suphead{display:flex;align-items:center;gap:13px;margin-bottom:16px}\n.suplogo{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff;font-size:15px}\n.supmeta{display:grid;grid-template-columns:1fr 1fr;gap:13px 16px;padding-top:15px;border-top:1px solid #f1f4f8}\n.smi .l{font-size:11px;color:#8b98ad;font-weight:600}\n.smi .v{font-size:14px;font-weight:600;margin-top:2px}\n.statusdot{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#0f8a4d}\n.statusdot .sd{width:8px;height:8px;border-radius:50%;background:#22b562}\n/* MOBILE */\n.mobwrap{display:flex;gap:34px;flex-wrap:wrap;justify-content:center;padding:14px 0}\n.phone{width:300px;height:620px;background:#0e1a2b;border-radius:40px;padding:11px;box-shadow:0 24px 60px rgba(15,26,43,.28);flex-shrink:0}\n.pscreen{background:#f4f6f9;border-radius:30px;height:100%;overflow:hidden;position:relative;display:flex;flex-direction:column}\n.pnotch{position:absolute;top:0;left:50%;transform:translateX(-50%);width:120px;height:26px;background:#0e1a2b;border-radius:0 0 16px 16px;z-index:10}\n.pstatus{padding:11px 20px 6px;display:flex;justify-content:space-between;font-size:12px;font-weight:600;color:#16202e}\n.pbody{flex:1;overflow-y:auto;padding:8px 16px 20px}\n.mlabel{text-align:center;font-size:13px;font-weight:600;color:#55637b;margin-top:14px}\n.phead{background:linear-gradient(150deg,#173163,#1d64f0);color:#fff;border-radius:16px;padding:15px 16px;margin-bottom:14px}\n.pbtn{width:100%;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px}\n.mcard{background:#fff;border:1px solid #e4e9f1;border-radius:14px;padding:14px;margin-bottom:12px}\n.mstep{display:flex;align-items:center;gap:11px;padding:8px 0}\n.mnode{width:26px;height:26px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700}\n.mn-done{background:#22b562;color:#fff}.mn-next{background:#1d64f0;color:#fff}.mn-idle{background:#eef1f6;color:#a7b2c4}\n.pill{font-size:11px;font-weight:700;padding:3px 9px;border-radius:20px}\n.hide{display:none}\n<\u002Fstyle>\n<\u002Fhelmet>\n<div>\n<sc-if value=\"{{ showAuth }}\" hint-placeholder-val=\"{{ true }}\">\n<div class=\"auth\">\n<div class=\"authbrand\">\n<div class=\"abrow\"><div class=\"ablogo\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"><\u002Frect><path d=\"M16 8h4l3 3v5h-7V8z\"><\u002Fpath><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"><\u002Fcircle><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"><\u002Fcircle><\u002Fsvg><\u002Fdiv><div><div class=\"abname\">WindowTime<\u002Fdiv><div class=\"abtag\">Logistics Window Time Tracking<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<div class=\"ahead\">บริหารคิวรถขนส่ง<br>ให้ตรงเวลา ทุกเที่ยว<\u002Fdiv>\n<div class=\"asub\">ระบบจองและติดตาม Window Time สำหรับทีมคลัง Supplier และคนขับรถ — ข้อมูลซิงก์กับ Google Sheet แบบเรียลไทม์<\u002Fdiv>\n<div class=\"astats\"><div class=\"astat\"><div class=\"n mono\">1,240+<\u002Fdiv><div class=\"l\">เที่ยวต่อเดือน<\u002Fdiv><\u002Fdiv><div class=\"astat\"><div class=\"n mono\">78%<\u002Fdiv><div class=\"l\">ตรงเวลาเฉลี่ย<\u002Fdiv><\u002Fdiv><div class=\"astat\"><div class=\"n mono\">32<\u002Fdiv><div class=\"l\">Supplier<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<div class=\"authform\">\n<sc-if value=\"{{ isLogin }}\" hint-placeholder-val=\"{{ true }}\">\n<div class=\"authcard\">\n<div class=\"at\">เข้าสู่ระบบ<\u002Fdiv>\n<div class=\"ap\">ยินดีต้อนรับกลับ — เลือกบทบาทเพื่อทดลองใช้งาน<\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">อีเมล<\u002Flabel><input class=\"inp\" type=\"email\" value=\"{{ form.email }}\" oninput=\"{{ f.email }}\" placeholder=\"you@company.com\"><\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">รหัสผ่าน<\u002Flabel><input class=\"inp\" type=\"password\" value=\"{{ form.pw }}\" oninput=\"{{ f.pw }}\" placeholder=\"••••••••\"><\u002Fdiv>\n<div class=\"divider\">เข้าใช้งานเป็น (ตัวอย่าง)<\u002Fdiv>\n<div class=\"roles\">\n<sc-for list=\"{{ loginRoles }}\" as=\"r\" hint-placeholder-count=\"4\"><button class=\"rolebtn {{ r.cls }}\" onclick=\"{{ r.pick }}\"><span class=\"rbic\" style=\"{{ r.icbg }}\">{{ r.emoji }}<\u002Fspan><span><span class=\"rbt\">{{ r.title }}<\u002Fspan><span class=\"rbs\">{{ r.sub }}<\u002Fspan><\u002Fspan><\u002Fbutton><\u002Fsc-for>\n<\u002Fdiv>\n<button class=\"btn btn-pri btn-blk\" onclick=\"{{ doLogin }}\">เข้าสู่ระบบ →<\u002Fbutton>\n<div class=\"authlink\">ยังไม่มีบัญชี? <a onclick=\"{{ goRegister }}\" style=\"cursor:pointer;font-weight:600\">สมัครสมาชิก<\u002Fa><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n<sc-if value=\"{{ isRegister }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"authcard\">\n<div class=\"at\">สมัครสมาชิก<\u002Fdiv>\n<div class=\"ap\">สร้างบัญชีสำหรับ Supplier หรือคนขับรถ<\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">ประเภทผู้ใช้งาน<\u002Flabel>\n<div class=\"roles\"><sc-for list=\"{{ regRoles }}\" as=\"r\" hint-placeholder-count=\"3\"><button class=\"rolebtn {{ r.cls }}\" onclick=\"{{ r.pick }}\"><span class=\"rbic\" style=\"{{ r.icbg }}\">{{ r.emoji }}<\u002Fspan><span><span class=\"rbt\">{{ r.title }}<\u002Fspan><\u002Fspan><\u002Fbutton><\u002Fsc-for><\u002Fdiv>\n<\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">ชื่อ–นามสกุล / ชื่อบริษัท<\u002Flabel><input class=\"inp\" value=\"{{ form.rname }}\" oninput=\"{{ f.rname }}\" placeholder=\"เช่น สมชาย ใจดี / บจก. ทรานสปอร์ต\"><\u002Fdiv>\n<div class=\"frow\"><div class=\"field\"><label class=\"lbl\">อีเมล<\u002Flabel><input class=\"inp\" value=\"{{ form.email }}\" oninput=\"{{ f.email }}\" placeholder=\"you@company.com\"><\u002Fdiv><div class=\"field\"><label class=\"lbl\">เบอร์โทร<\u002Flabel><input class=\"inp\" value=\"{{ form.phone }}\" oninput=\"{{ f.phone }}\" placeholder=\"08x-xxx-xxxx\"><\u002Fdiv><\u002Fdiv>\n<div class=\"frow\"><div class=\"field\"><label class=\"lbl\">รหัสผ่าน<\u002Flabel><input class=\"inp\" type=\"password\" value=\"{{ form.pw }}\" oninput=\"{{ f.pw }}\" placeholder=\"••••••••\"><\u002Fdiv><div class=\"field\"><label class=\"lbl\">ยืนยันรหัสผ่าน<\u002Flabel><input class=\"inp\" type=\"password\" value=\"{{ form.pw2 }}\" oninput=\"{{ f.pw2 }}\" placeholder=\"••••••••\"><\u002Fdiv><\u002Fdiv>\n<button class=\"btn btn-pri btn-blk\" onclick=\"{{ doRegister }}\">สมัครและเข้าใช้งาน →<\u002Fbutton>\n<div class=\"authlink\">มีบัญชีแล้ว? <a onclick=\"{{ goLogin }}\" style=\"cursor:pointer;font-weight:600\">เข้าสู่ระบบ<\u002Fa><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<sc-if value=\"{{ showApp }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"app\">\n<aside class=\"side\">\n<div class=\"brand\"><div class=\"logo\"><svg class=\"ic\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"><\u002Frect><path d=\"M16 8h4l3 3v5h-7V8z\"><\u002Fpath><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"><\u002Fcircle><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"><\u002Fcircle><\u002Fsvg><\u002Fdiv><div><div class=\"bname\">WindowTime<\u002Fdiv><div class=\"bsub\">Logistics Control<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<div class=\"navlab\">ปฏิบัติการ<\u002Fdiv>\n<div class=\"navlink {{ nc.dashboard }}\" onclick=\"{{ go.dashboard }}\"><svg class=\"ic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"9\"><\u002Frect><rect x=\"14\" y=\"3\" width=\"7\" height=\"5\"><\u002Frect><rect x=\"14\" y=\"12\" width=\"7\" height=\"9\"><\u002Frect><rect x=\"3\" y=\"16\" width=\"7\" height=\"5\"><\u002Frect><\u002Fsvg>Dashboard<\u002Fdiv>\n<div class=\"navlink {{ nc.calendar }}\" onclick=\"{{ go.calendar }}\"><svg class=\"ic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"><\u002Frect><path d=\"M16 2v4M8 2v4M3 10h18\"><\u002Fpath><\u002Fsvg>ปฏิทิน Window<\u002Fdiv>\n<div class=\"navlink {{ nc.booking }}\" onclick=\"{{ go.booking }}\"><svg class=\"ic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 11l3 3L22 4\"><\u002Fpath><path d=\"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11\"><\u002Fpath><\u002Fsvg>จอง / จัดคิว<\u002Fdiv>\n<div class=\"navlink {{ nc.kpi }}\" onclick=\"{{ go.kpi }}\"><svg class=\"ic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 3v18h18\"><\u002Fpath><path d=\"M18 17V9M13 17V5M8 17v-3\"><\u002Fpath><\u002Fsvg>รายงาน KPI<\u002Fdiv>\n<div class=\"navlab\">ผู้ใช้ &amp; ทรัพยากร<\u002Fdiv>\n<div class=\"navlink {{ nc.supplier }}\" onclick=\"{{ go.supplier }}\"><svg class=\"ic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"><\u002Fpath><circle cx=\"9\" cy=\"7\" r=\"4\"><\u002Fcircle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75\"><\u002Fpath><\u002Fsvg>Supplier<\u002Fdiv>\n<div class=\"navlink {{ nc.driver }}\" onclick=\"{{ go.driver }}\"><svg class=\"ic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2\"><\u002Fpath><circle cx=\"7.5\" cy=\"17.5\" r=\"2.5\"><\u002Fcircle><circle cx=\"17.5\" cy=\"17.5\" r=\"2.5\"><\u002Fcircle><\u002Fsvg>คนขับรถ<\u002Fdiv>\n<div class=\"navlink {{ nc.mobile }}\" onclick=\"{{ go.mobile }}\"><svg class=\"ic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"5\" y=\"2\" width=\"14\" height=\"20\" rx=\"2\"><\u002Frect><path d=\"M12 18h.01\"><\u002Fpath><\u002Fsvg>มุมมองมือถือ<\u002Fdiv>\n<div class=\"sheetbox\"><div class=\"fx ac gap8\" style=\"display:flex;align-items:center;gap:8px;font-size:12px;font-weight:600;color:#e6ecfa\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"#22b562\"><path d=\"M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zm-9 14H7v-2h3v2zm0-4H7v-2h3v2zm0-4H7V7h3v2zm7 8h-5v-2h5v2zm0-4h-5v-2h5v2zm0-4h-5V7h5v2z\"><\u002Fpath><\u002Fsvg>Google Sheet<\u002Fdiv><div style=\"font-size:11px;color:#7d8bab;margin-top:5px;line-height:1.4\">ฐานข้อมูล 2026 · เชื่อมต่ออยู่<\u002Fdiv><\u002Fdiv>\n<div class=\"sidefoot\"><div class=\"avatar\">{{ user.initials }}<\u002Fdiv><div style=\"line-height:1.25\"><div style=\"font-size:13px;font-weight:600;color:#eef3fb\">{{ user.name }}<\u002Fdiv><div style=\"font-size:11px;color:#7d8bab\">{{ user.roleLabel }}<\u002Fdiv><\u002Fdiv><button class=\"lgout\" onclick=\"{{ logout }}\" title=\"ออกจากระบบ\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4\"><\u002Fpath><path d=\"M16 17l5-5-5-5M21 12H9\"><\u002Fpath><\u002Fsvg><\u002Fbutton><\u002Fdiv>\n<\u002Faside>\n<main class=\"main\">\n<div class=\"topbar\">\n<div class=\"h1\">{{ pageTitle }}<span>{{ pageSub }}<\u002Fspan><\u002Fdiv>\n<div class=\"sync\"><svg class=\"syncic\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\"><path d=\"M23 4v6h-6M1 20v-6h6\"><\u002Fpath><path d=\"M3.5 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.5 15\"><\u002Fpath><\u002Fsvg>ซิงก์ Google Sheet<\u002Fdiv>\n<div class=\"userchip\"><div style=\"text-align:right\"><div class=\"uc-name\">{{ user.name }}<\u002Fdiv><span class=\"rolebadge {{ user.roleCls }}\">{{ user.roleLabel }}<\u002Fspan><\u002Fdiv><div class=\"uc-av\">{{ user.initials }}<\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n\n<!-- DASHBOARD -->\n<sc-if value=\"{{ pgDash }}\" hint-placeholder-val=\"{{ true }}\">\n<div class=\"wrap\">\n<div style=\"display:flex;align-items:center;margin-bottom:16px\"><div class=\"clock\" style=\"text-align:left\"><div class=\"clocktime mono\"><span class=\"livedot\"><\u002Fspan>{{ clock }} น.<\u002Fdiv><div class=\"clockdate\">{{ dateLabel }}<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<div class=\"kpis\">\n<div class=\"kpi\"><div class=\"kl\"><span class=\"dot\" style=\"background:#22b562\"><\u002Fspan>ตรงเวลา (On-time)<\u002Fdiv><div class=\"kv\">{{ k.onTime }}<small>%<\u002Fsmall><\u002Fdiv><div class=\"kt up\">▲ ดีขึ้น 6% จากเมื่อวาน<\u002Fdiv><\u002Fdiv>\n<div class=\"kpi\"><div class=\"kl\"><span class=\"dot\" style=\"background:#1d64f0\"><\u002Fspan>คิววันนี้ (Total)<\u002Fdiv><div class=\"kv\">{{ k.total }}<\u002Fdiv><div class=\"kt flat\">{{ k.doneCount }} เสร็จ · {{ k.remain }} รอ<\u002Fdiv><\u002Fdiv>\n<div class=\"kpi\"><div class=\"kl\"><span class=\"dot\" style=\"background:#f59e0b\"><\u002Fspan>กำลังดำเนินการ<\u002Fdiv><div class=\"kv\">{{ k.active }}<\u002Fdiv><div class=\"kt flat\">ขึ้นของ / เดินทาง / ลงของ<\u002Fdiv><\u002Fdiv>\n<div class=\"kpi\"><div class=\"kl\"><span class=\"dot\" style=\"background:#e0344b\"><\u002Fspan>ล่าช้า / มีปัญหา<\u002Fdiv><div class=\"kv\">{{ k.delayed }}<\u002Fdiv><div class=\"kt down\">ต้องติดตาม {{ k.delayed }} คิว<\u002Fdiv><\u002Fdiv>\n<div class=\"kpi\"><div class=\"kl\"><span class=\"dot\" style=\"background:#6d5ae0\"><\u002Fspan>เวลาเฉลี่ยหน้าท่า<\u002Fdiv><div class=\"kv\">{{ k.avgDwell }}<small> นาที<\u002Fsmall><\u002Fdiv><div class=\"kt flat\">Dwell time ต้นทาง<\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<div class=\"card mb18\">\n<div class=\"card-h\"><div class=\"card-t\">ผังช่วงเวลา &amp; ช่องขึ้นสินค้า<small>Window Slots · Loading Dock<\u002Fsmall><\u002Fdiv><div class=\"subt\" style=\"margin-left:auto\">07:00 – 18:00 น.<\u002Fdiv><\u002Fdiv>\n<div class=\"gantt\">\n<div class=\"axis\"><sc-for list=\"{{ ticks }}\" as=\"t\" hint-placeholder-count=\"12\"><div class=\"tick\">{{ t }}<\u002Fdiv><\u002Fsc-for><\u002Fdiv>\n<sc-for list=\"{{ docks }}\" as=\"d\" hint-placeholder-count=\"4\"><div class=\"track\"><div class=\"tname\">{{ d.name }}<\u002Fdiv><div class=\"lane\"><sc-for list=\"{{ d.slots }}\" as=\"s\" hint-placeholder-count=\"2\"><div class=\"slot\" style=\"{{ s.style }}\" onclick=\"{{ s.open }}\">{{ s.label }}<\u002Fdiv><\u002Fsc-for><\u002Fdiv><\u002Fdiv><\u002Fsc-for>\n<div class=\"nowwrap\"><div class=\"nowline\" style=\"{{ nowStyle }}\"><\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fdiv>\n<div class=\"grid2\">\n<div class=\"card\">\n<div class=\"card-h\"><div class=\"card-t\">คิวขนส่งวันนี้<small>Live Queue Board<\u002Fsmall><\u002Fdiv><div class=\"filters\"><sc-for list=\"{{ filters }}\" as=\"fl\" hint-placeholder-count=\"4\"><div class=\"chip {{ fl.cls }}\" onclick=\"{{ fl.set }}\">{{ fl.label }}<span class=\"c\">{{ fl.count }}<\u002Fspan><\u002Fdiv><\u002Fsc-for><\u002Fdiv><\u002Fdiv>\n<sc-for list=\"{{ rows }}\" as=\"r\" hint-placeholder-count=\"6\">\n<\u002Fsc-for><table><thead><tr><th>คิว<\u002Fth><th>ลูกค้า / Order<\u002Fth><th>รถ · คนขับ<\u002Fth><th>Window · ท่า<\u002Fth><th>ความคืบหน้า<\u002Fth><th>สถานะ<\u002Fth><\u002Ftr><\u002Fthead>\n<tbody><tr class=\"clik {{ r.selCls }}\" onclick=\"{{ r.open }}\"><td><div class=\"qno\">{{ r.q }}<\u002Fdiv><\u002Ftd><td><div class=\"cust\">{{ r.customer }}<\u002Fdiv><div class=\"subt mono\">{{ r.order }} · {{ r.dest }}<\u002Fdiv><\u002Ftd><td><div class=\"veh\"><span class=\"tt\">{{ r.truck }}<\u002Fspan><div><div style=\"font-weight:600\" class=\"mono\">{{ r.plate }}<\u002Fdiv><div class=\"{{ r.fleetCls }}\">{{ r.driver }} · {{ r.fleetLabel }}<\u002Fdiv><\u002Fdiv><\u002Fdiv><\u002Ftd><td><div class=\"win mono\">{{ r.window }}<\u002Fdiv><div class=\"subt\">{{ r.dock }}<\u002Fdiv><\u002Ftd><td><div class=\"progwrap\"><div class=\"progbar\"><div class=\"progfill\" style=\"{{ r.progStyle }}\"><\u002Fdiv><\u002Fdiv><span class=\"progpct mono\">{{ r.progPct }}%<\u002Fspan><\u002Fdiv><\u002Ftd><td><span class=\"badge {{ r.phCls }}\"><span class=\"bd\"><\u002Fspan>{{ r.phLabel }}<\u002Fspan><sc-if value=\"{{ r.hasTag }}\" hint-placeholder-val=\"{{ false }}\"><span class=\"tag {{ r.tagCls }}\">{{ r.tagLabel }}<\u002Fspan><\u002Fsc-if><\u002Ftd><\u002Ftr>\n<\u002Ftbody><\u002Ftable>\n<\u002Fdiv>\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">การแจ้งเตือน<small>Delay Alerts<\u002Fsmall><\u002Fdiv><span class=\"badge tag-issue\" style=\"margin-left:auto;border-radius:6px\">{{ alerts.length }}<\u002Fspan><\u002Fdiv>\n<sc-for list=\"{{ alerts }}\" as=\"a\" hint-placeholder-count=\"3\"><div class=\"alert\" onclick=\"{{ a.open }}\"><div class=\"aic {{ a.cls }}\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z\"><\u002Fpath><line x1=\"12\" y1=\"9\" x2=\"12\" y2=\"13\"><\u002Fline><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"><\u002Fline><\u002Fsvg><\u002Fdiv><div><div class=\"atitle\">คิว {{ a.q }} · {{ a.customer }} <span class=\"tag {{ a.tagCls }}\">{{ a.tagLabel }}<\u002Fspan><\u002Fdiv><div class=\"amsg\">{{ a.msg }}<\u002Fdiv><\u002Fdiv><\u002Fdiv><\u002Fsc-for>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<!-- CALENDAR -->\n<sc-if value=\"{{ pgCal }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"wrap\">\n<div class=\"calgrid\">\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">กรกฎาคม 2569<small>July 2026 · คิวขนส่งรายวัน<\u002Fsmall><\u002Fdiv><div class=\"subt\" style=\"margin-left:auto\">คลิกวันเพื่อดูรายละเอียด<\u002Fdiv><\u002Fdiv>\n<div class=\"cal\"><div class=\"calhead\"><div class=\"cah\">อา<\u002Fdiv><div class=\"cah\">จ<\u002Fdiv><div class=\"cah\">อ<\u002Fdiv><div class=\"cah\">พ<\u002Fdiv><div class=\"cah\">พฤ<\u002Fdiv><div class=\"cah\">ศ<\u002Fdiv><div class=\"cah\">ส<\u002Fdiv><\u002Fdiv>\n<div class=\"calbody\"><sc-for list=\"{{ calCells }}\" as=\"c\" hint-placeholder-count=\"35\"><div class=\"cell {{ c.cls }}\" onclick=\"{{ c.pick }}\"><sc-if value=\"{{ c.day }}\" hint-placeholder-val=\"{{ true }}\"><div class=\"cd\">{{ c.day }}<\u002Fdiv><sc-if value=\"{{ c.count }}\" hint-placeholder-val=\"{{ false }}\"><div class=\"ccount\"><span class=\"cdot\"><\u002Fspan>{{ c.count }} คิว<\u002Fdiv><\u002Fsc-if><\u002Fsc-if><\u002Fdiv><\u002Fsc-for><\u002Fdiv>\n<\u002Fdiv><\u002Fdiv>\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">{{ daySel.title }}<small>{{ daySel.count }} คิว<\u002Fsmall><\u002Fdiv><\u002Fdiv>\n<div class=\"dsched\"><sc-for list=\"{{ daySel.items }}\" as=\"d\" hint-placeholder-count=\"6\"><div class=\"dsitem\"><div class=\"qno\">{{ d.q }}<\u002Fdiv><div style=\"flex:1\"><div class=\"cust\">{{ d.customer }}<\u002Fdiv><div class=\"route\"><span class=\"tt\">{{ d.truck }}<\u002Fspan> ปลายทาง {{ d.dest }} · <span class=\"mono\">{{ d.window }}<\u002Fspan><\u002Fdiv><\u002Fdiv><span class=\"badge {{ d.phCls }}\"><span class=\"bd\"><\u002Fspan>{{ d.phLabel }}<\u002Fspan><\u002Fdiv><\u002Fsc-for>\n<sc-if value=\"{{ daySel.empty }}\" hint-placeholder-val=\"{{ false }}\"><div class=\"emptyb\">ไม่มีคิวขนส่งในวันนี้<\u002Fdiv><\u002Fsc-if>\n<\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<!-- BOOKING -->\n<sc-if value=\"{{ pgBook }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"wrap\">\n<sc-if value=\"{{ noPlanPerm }}\" hint-placeholder-val=\"{{ false }}\"><div class=\"lockbar\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"><\u002Frect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"><\u002Fpath><\u002Fsvg>หน้าจัดคิวแก้ไขได้เฉพาะ <b>&nbsp;ฝ่ายวางแผน&nbsp;<\u002Fb> เท่านั้น — ขณะนี้คุณเข้าใช้เป็น {{ user.roleLabel }} (ดูอย่างเดียว)<\u002Fdiv><\u002Fsc-if>\n<div class=\"formgrid\">\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">จัดคิว / กำหนดปลายทาง<small>ฝ่ายวางแผน · บันทึกลง Google Sheet<\u002Fsmall><\u002Fdiv><\u002Fdiv>\n<div class=\"formbody {{ lockCls }}\">\n<div class=\"frow\"><div class=\"field\"><label class=\"lbl\">วันที่ <span class=\"subt\">(ค่าเริ่มต้น = วันนี้)<\u002Fspan><\u002Flabel><input class=\"inp\" type=\"date\" value=\"{{ form.date }}\" oninput=\"{{ f.date }}\"><\u002Fdiv><div class=\"field\"><label class=\"lbl\">คิวที่<\u002Flabel><input class=\"inp mono\" type=\"number\" min=\"1\" value=\"{{ form.queue }}\" oninput=\"{{ f.queue }}\"><\u002Fdiv><\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">ลูกค้า<\u002Flabel><input class=\"inp\" value=\"{{ form.customer }}\" oninput=\"{{ f.customer }}\" placeholder=\"ชื่อลูกค้า / บริษัท\"><\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">ปลายทาง <span class=\"subt\">(หลายจุด = multi-drop · คงคิวเดิมจนจบรอบ)<\u002Fspan><\u002Flabel><div style=\"display:flex;gap:10px\"><input class=\"inp\" value=\"{{ form.dest }}\" oninput=\"{{ f.dest }}\" onkeydown=\"{{ onDestKey }}\" placeholder=\"พิมพ์ปลายทางแล้วกด Enter\"><button class=\"btn btn-gho\" onclick=\"{{ addDest }}\">เพิ่ม<\u002Fbutton><\u002Fdiv>\n<div class=\"dests\"><sc-for list=\"{{ destChips }}\" as=\"d\" hint-placeholder-count=\"1\"><span class=\"destchip\">{{ d.name }}<span class=\"destx\" onclick=\"{{ d.remove }}\">✕<\u002Fspan><\u002Fspan><\u002Fsc-for><\u002Fdiv><\u002Fdiv>\n<div class=\"frow\"><div class=\"field\"><label class=\"lbl\">ช่วงเวลาเข้า (Window)<\u002Flabel><input class=\"inp\" type=\"time\" value=\"{{ form.ws }}\" oninput=\"{{ f.ws }}\"><\u002Fdiv><div class=\"field\"><label class=\"lbl\">ช่องขึ้นสินค้า<\u002Flabel><select class=\"inp\" value=\"{{ form.dock }}\" onchange=\"{{ f.dock }}\"><sc-for list=\"{{ dockOpts }}\" as=\"o\" hint-placeholder-count=\"10\"><option>{{ o }}<\u002Foption><\u002Fsc-for><\u002Fselect><\u002Fdiv><\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">ประเภทรถ<\u002Flabel><div class=\"seg\"><sc-for list=\"{{ fleetOpts }}\" as=\"o\" hint-placeholder-count=\"2\"><button class=\"segbtn {{ o.cls }}\" onclick=\"{{ o.pick }}\">{{ o.label }}<\u002Fbutton><\u002Fsc-for><\u002Fdiv><\u002Fdiv>\n<sc-if value=\"{{ isSubFleet }}\" hint-placeholder-val=\"{{ false }}\"><div class=\"field\"><label class=\"lbl\">บริษัท Sub (Subcontractor)<\u002Flabel><input class=\"inp\" value=\"{{ form.subco }}\" oninput=\"{{ f.subco }}\" placeholder=\"ชื่อรถ/บริษัทของซัพพลายเออร์\"><\u002Fdiv><\u002Fsc-if>\n<div class=\"frow3\"><div class=\"field\"><label class=\"lbl\">ทะเบียนรถ<\u002Flabel><select class=\"inp\" value=\"{{ form.plate }}\" onchange=\"{{ f.plate }}\"><sc-for list=\"{{ plateOpts }}\" as=\"o\" hint-placeholder-count=\"10\"><option>{{ o }}<\u002Foption><\u002Fsc-for><\u002Fselect><\u002Fdiv><div class=\"field\"><label class=\"lbl\">คนขับรถ<\u002Flabel><select class=\"inp\" value=\"{{ form.driver }}\" onchange=\"{{ f.driver }}\"><sc-for list=\"{{ driverOpts }}\" as=\"o\" hint-placeholder-count=\"10\"><option>{{ o }}<\u002Foption><\u002Fsc-for><\u002Fselect><\u002Fdiv><div class=\"field\"><label class=\"lbl\">ประเภทรถ<\u002Flabel><select class=\"inp\" value=\"{{ form.truck }}\" onchange=\"{{ f.truck }}\"><sc-for list=\"{{ truckOpts }}\" as=\"o\" hint-placeholder-count=\"3\"><option>{{ o }}<\u002Foption><\u002Fsc-for><\u002Fselect><\u002Fdiv><\u002Fdiv>\n<button class=\"btn btn-pri btn-blk {{ lockCls }}\" onclick=\"{{ submitBooking }}\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\"><path d=\"M20 6L9 17l-5-5\"><\u002Fpath><\u002Fsvg>ยืนยันการจัดคิว · บันทึกลงชีต<\u002Fbutton>\n<\u002Fdiv><\u002Fdiv>\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">คิวที่จองในเซสชันนี้<small>{{ bookings.length }} รายการ<\u002Fsmall><\u002Fdiv><\u002Fdiv>\n<sc-if value=\"{{ noBookings }}\" hint-placeholder-val=\"{{ true }}\"><div class=\"emptyb\">ยังไม่มีคิวที่จอง<br>กรอกฟอร์มด้านซ้ายเพื่อเพิ่มคิวใหม่<\u002Fdiv><\u002Fsc-if>\n<div><sc-for list=\"{{ bookings }}\" as=\"b\" hint-placeholder-count=\"0\"><div class=\"dsitem\"><div class=\"qno\">{{ b.q }}<\u002Fdiv><div style=\"flex:1\"><div class=\"cust\">{{ b.customer }}<\u002Fdiv><div class=\"route\"><span class=\"tt\">{{ b.truck }}<\u002Fspan> {{ b.dock }} · <span class=\"mono\">{{ b.window }}<\u002Fspan> → {{ b.dest }}<\u002Fdiv><\u002Fdiv><span class=\"badge ph-sched\"><span class=\"bd\"><\u002Fspan>จองแล้ว<\u002Fspan><\u002Fdiv><\u002Fsc-for><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<!-- KPI REPORT -->\n<sc-if value=\"{{ pgKpi }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"wrap\">\n<div class=\"kpis\" style=\"grid-template-columns:repeat(4,1fr)\">\n<div class=\"kpi\"><div class=\"kl\">เที่ยวทั้งเดือน<\u002Fdiv><div class=\"kv mono\">1,240<\u002Fdiv><div class=\"kt up\">▲ 8% MoM<\u002Fdiv><\u002Fdiv>\n<div class=\"kpi\"><div class=\"kl\">On-time เฉลี่ย<\u002Fdiv><div class=\"kv\">78<small>%<\u002Fsmall><\u002Fdiv><div class=\"kt up\">▲ เป้า 85%<\u002Fdiv><\u002Fdiv>\n<div class=\"kpi\"><div class=\"kl\">Dwell เฉลี่ย<\u002Fdiv><div class=\"kv\">44<small> นาที<\u002Fsmall><\u002Fdiv><div class=\"kt down\">▲ ช้าลง 3 นาที<\u002Fdiv><\u002Fdiv>\n<div class=\"kpi\"><div class=\"kl\">เที่ยวที่มีปัญหา<\u002Fdiv><div class=\"kv mono\">96<\u002Fdiv><div class=\"kt flat\">7.7% ของทั้งหมด<\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<div class=\"kgrid mb18\">\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">แนวโน้ม On-time %<small>7 วันล่าสุด<\u002Fsmall><\u002Fdiv><\u002Fdiv><div class=\"bars\"><sc-for list=\"{{ trend }}\" as=\"t\" hint-placeholder-count=\"7\"><div class=\"barcol\"><div class=\"barv mono\">{{ t.v }}%<\u002Fdiv><div class=\"bar\" style=\"{{ t.style }}\"><\u002Fdiv><div class=\"barl\">{{ t.label }}<\u002Fdiv><\u002Fdiv><\u002Fsc-for><\u002Fdiv><\u002Fdiv>\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">สัดส่วนสถานะ<small>Status Breakdown<\u002Fsmall><\u002Fdiv><\u002Fdiv><div class=\"donutwrap\"><div class=\"donut\" style=\"{{ donutStyle }}\"><div class=\"dcenter\"><div class=\"dcv\">78%<\u002Fdiv><div class=\"dcl\">ตรงเวลา<\u002Fdiv><\u002Fdiv><\u002Fdiv><div class=\"legend\"><sc-for list=\"{{ breakdown }}\" as=\"b\" hint-placeholder-count=\"4\"><div class=\"lgi\"><span class=\"lgsw\" style=\"{{ b.sw }}\"><\u002Fspan>{{ b.label }}<span class=\"lgv mono\">{{ b.v }}%<\u002Fspan><\u002Fdiv><\u002Fsc-for><\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">On-time แยกตามผู้ให้บริการ<small>On-time by Carrier<\u002Fsmall><\u002Fdiv><\u002Fdiv><div class=\"hbars\"><sc-for list=\"{{ byCarrier }}\" as=\"c\" hint-placeholder-count=\"4\"><div class=\"hbrow\"><div class=\"hbname\">{{ c.name }}<\u002Fdiv><div class=\"hbtrack\"><div class=\"hbfill\" style=\"{{ c.style }}\"><\u002Fdiv><\u002Fdiv><div class=\"hbv mono\">{{ c.v }}%<\u002Fdiv><\u002Fdiv><\u002Fsc-for><\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<!-- SUPPLIER -->\n<sc-if value=\"{{ pgSup }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"wrap\">\n<div class=\"supgrid\"><sc-for list=\"{{ suppliers }}\" as=\"s\" hint-placeholder-count=\"4\">\n<div class=\"supcard\"><div class=\"suphead\"><div class=\"suplogo\" style=\"{{ s.logobg }}\">{{ s.abbr }}<\u002Fdiv><div style=\"flex:1\"><div style=\"font-weight:700;font-size:16px\">{{ s.name }}<\u002Fdiv><div class=\"subt\">{{ s.type }} · ผู้ติดต่อ {{ s.contact }}<\u002Fdiv><\u002Fdiv><span class=\"statusdot\"><span class=\"sd\"><\u002Fspan>ใช้งาน<\u002Fspan><\u002Fdiv>\n<div class=\"supmeta\"><div class=\"smi\"><div class=\"l\">เบอร์ติดต่อ<\u002Fdiv><div class=\"v mono\">{{ s.phone }}<\u002Fdiv><\u002Fdiv><div class=\"smi\"><div class=\"l\">จำนวนรถ<\u002Fdiv><div class=\"v\">{{ s.fleetSize }} คัน<\u002Fdiv><\u002Fdiv><div class=\"smi\"><div class=\"l\">ประเภทรถ<\u002Fdiv><div class=\"v\">{{ s.trucks }}<\u002Fdiv><\u002Fdiv><div class=\"smi\"><div class=\"l\">คิวเดือนนี้<\u002Fdiv><div class=\"v mono\">{{ s.queues }}<\u002Fdiv><\u002Fdiv><div class=\"smi\"><div class=\"l\">On-time<\u002Fdiv><div class=\"v\" style=\"{{ s.otColor }}\">{{ s.ontime }}%<\u002Fdiv><\u002Fdiv><div class=\"smi\"><div class=\"l\">มีปัญหา<\u002Fdiv><div class=\"v\">{{ s.issues }} ครั้ง<\u002Fdiv><\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<\u002Fsc-for><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<!-- DRIVER -->\n<sc-if value=\"{{ pgDrv }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"wrap\">\n<div class=\"card\"><div class=\"card-h\"><div class=\"card-t\">ทะเบียนคนขับรถ<small>{{ drivers.length }} คน · Google Sheet<\u002Fsmall><\u002Fdiv><\u002Fdiv>\n<sc-for list=\"{{ drivers }}\" as=\"d\" hint-placeholder-count=\"10\"><\u002Fsc-for><table><thead><tr><th>คนขับ<\u002Fth><th>เบอร์โทร<\u002Fth><th>ทะเบียน<\u002Fth><th>ประเภทรถ<\u002Fth><th>สังกัด<\u002Fth><th>เที่ยววันนี้<\u002Fth><th>On-time<\u002Fth><th>สถานะ<\u002Fth><\u002Ftr><\u002Fthead>\n<tbody><tr><td><div class=\"veh\"><div class=\"avatar\" style=\"background:#eaf0fb;color:#1d4fbf\">{{ d.ini }}<\u002Fdiv><span class=\"cust\">{{ d.name }}<\u002Fspan><\u002Fdiv><\u002Ftd><td class=\"mono subt\">{{ d.phone }}<\u002Ftd><td class=\"mono\" style=\"font-weight:600\">{{ d.plate }}<\u002Ftd><td><span class=\"tt\">{{ d.truck }}<\u002Fspan><\u002Ftd><td><span class=\"{{ d.fleetCls }}\">{{ d.company }}<\u002Fspan><\u002Ftd><td class=\"mono\">{{ d.trips }}<\u002Ftd><td class=\"mono\" style=\"font-weight:600;{{ d.otColor }}\">{{ d.ontime }}%<\u002Ftd><td><span class=\"badge {{ d.stCls }}\"><span class=\"bd\"><\u002Fspan>{{ d.stLabel }}<\u002Fspan><\u002Ftd><\u002Ftr><\u002Ftbody><\u002Ftable>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<!-- MOBILE -->\n<sc-if value=\"{{ pgMob }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"wrap\">\n<div class=\"subt\" style=\"text-align:center;font-size:13.5px;margin-bottom:6px\">ตัวอย่างการใช้งานบนมือถือ — คนขับรถเช็คอินหน้างาน และ Supplier ดู/จองคิว<\u002Fdiv>\n<div class=\"mobwrap\">\n<div><div class=\"phone\"><div class=\"pscreen\"><div class=\"pnotch\"><\u002Fdiv><div class=\"pstatus\"><span class=\"mono\">9:41<\u002Fspan><span>📶 🔋<\u002Fspan><\u002Fdiv><div class=\"pbody\">\n<div class=\"phead\" style=\"background:linear-gradient(150deg,#7a4e12,#b26b06)\"><div style=\"font-size:12px;opacity:.85\">คนขับรถ<\u002Fdiv><div style=\"font-size:18px;font-weight:700\">สมชาย ใจดี<\u002Fdiv><div style=\"font-size:12px;opacity:.85;margin-top:2px\">1กน-1234 · 4W · Own Fleet<\u002Fdiv><\u002Fdiv>\n<div style=\"font-weight:700;font-size:14px;margin-bottom:8px\">คิวของฉันวันนี้<\u002Fdiv>\n<div class=\"mcard\"><div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px\"><span class=\"qno\">4<\u002Fspan><span class=\"pill ph-active\" style=\"background:#fff2dc;color:#b26b06\">กำลังเดินทาง<\u002Fspan><\u002Fdiv><div class=\"cust\">บจก. บิ๊กซี ซัพพลาย<\u002Fdiv><div class=\"route\" style=\"margin-top:4px\">Window <span class=\"mono\">11:00–11:30<\u002Fspan> · ท่า 3<\u002Fdiv><div class=\"route\">ปลายทาง ศูนย์ฯ สุวรรณภูมิ<\u002Fdiv><\u002Fdiv>\n<div class=\"mcard\"><div class=\"sec\" style=\"margin:0 0 10px\">สถานะการเดินทาง<\u002Fdiv>\n<div class=\"mstep\"><div class=\"mnode mn-done\">✓<\u002Fdiv><div style=\"flex:1\">มาถึงต้นทาง<\u002Fdiv><span class=\"mono\">11:45<\u002Fspan><\u002Fdiv>\n<div class=\"mstep\"><div class=\"mnode mn-done\">✓<\u002Fdiv><div style=\"flex:1\">ขึ้นสินค้าเสร็จ<\u002Fdiv><span class=\"mono\">12:30<\u002Fspan><\u002Fdiv>\n<div class=\"mstep\"><div class=\"mnode mn-done\">✓<\u002Fdiv><div style=\"flex:1\">ออกจากต้นทาง<\u002Fdiv><span class=\"mono\">12:40<\u002Fspan><\u002Fdiv>\n<div class=\"mstep\"><div class=\"mnode mn-next\">4<\u002Fdiv><div style=\"flex:1;font-weight:600\">ถึงปลายทาง<\u002Fdiv><span class=\"mono subt\">รอบันทึก<\u002Fspan><\u002Fdiv>\n<\u002Fdiv>\n<button class=\"pbtn btn-pri\" style=\"background:#b26b06\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"><path d=\"M20 6L9 17l-5-5\"><\u002Fpath><\u002Fsvg>เช็คอิน: ถึงปลายทาง<\u002Fbutton>\n<\u002Fdiv><\u002Fdiv><\u002Fdiv><div class=\"mlabel\">แอปคนขับรถ · เช็คอิน<\u002Fdiv><\u002Fdiv>\n\n<div><div class=\"phone\"><div class=\"pscreen\"><div class=\"pnotch\"><\u002Fdiv><div class=\"pstatus\"><span class=\"mono\">9:41<\u002Fspan><span>📶 🔋<\u002Fspan><\u002Fdiv><div class=\"pbody\">\n<div class=\"phead\"><div style=\"font-size:12px;opacity:.85\">Supplier<\u002Fdiv><div style=\"font-size:18px;font-weight:700\">Transport A<\u002Fdiv><div style=\"font-size:12px;opacity:.85;margin-top:2px\">คุณสมศักดิ์ · 8 คัน<\u002Fdiv><\u002Fdiv>\n<div style=\"display:flex;gap:10px;margin-bottom:12px\"><div class=\"mcard\" style=\"flex:1;margin:0;text-align:center\"><div class=\"kv\" style=\"font-size:24px\">74<small style=\"font-size:13px\">%<\u002Fsmall><\u002Fdiv><div class=\"subt\" style=\"font-size:11px\">On-time<\u002Fdiv><\u002Fdiv><div class=\"mcard\" style=\"flex:1;margin:0;text-align:center\"><div class=\"kv mono\" style=\"font-size:24px\">3<\u002Fdiv><div class=\"subt\" style=\"font-size:11px\">คิววันนี้<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<div style=\"font-weight:700;font-size:14px;margin-bottom:8px\">คิวที่จองไว้<\u002Fdiv>\n<div class=\"mcard\"><div style=\"display:flex;justify-content:space-between;margin-bottom:6px\"><span class=\"qno\">2<\u002Fspan><span class=\"pill ph-wait\" style=\"background:#e8f0fe;color:#1d5fd6\">กำลังลงของ<\u002Fspan><\u002Fdiv><div class=\"cust\">บมจ. ซีพี ค้าปลีก<\u002Fdiv><div class=\"route\" style=\"margin-top:3px\"><span class=\"mono\">09:00–09:30<\u002Fspan> · ท่า 2 · 6W<\u002Fdiv><\u002Fdiv>\n<div class=\"mcard\"><div style=\"display:flex;justify-content:space-between;margin-bottom:6px\"><span class=\"qno\">6<\u002Fspan><span class=\"pill ph-wait\" style=\"background:#e8f0fe;color:#1d5fd6\">มาถึงแล้ว<\u002Fspan><\u002Fdiv><div class=\"cust\">บมจ. สยามแม็คโคร<\u002Fdiv><div class=\"route\" style=\"margin-top:3px\"><span class=\"mono\">13:30–14:00<\u002Fspan> · ท่า 2 · 10W<\u002Fdiv><\u002Fdiv>\n<button class=\"pbtn btn-pri\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\"><path d=\"M12 5v14M5 12h14\"><\u002Fpath><\u002Fsvg>จอง Window ใหม่<\u002Fbutton>\n<\u002Fdiv><\u002Fdiv><\u002Fdiv><div class=\"mlabel\">แอป Supplier · จอง/ติดตามคิว<\u002Fdiv><\u002Fdiv>\n\n<div><div class=\"phone\"><div class=\"pscreen\"><div class=\"pnotch\"><\u002Fdiv><div class=\"pstatus\"><span class=\"mono\">9:41<\u002Fspan><span>📶 🔋<\u002Fspan><\u002Fdiv><div class=\"pbody\" style=\"display:flex;flex-direction:column;justify-content:center;padding:24px 20px\">\n<div class=\"logo\" style=\"width:52px;height:52px;border-radius:15px;margin:0 auto 18px\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"><\u002Frect><path d=\"M16 8h4l3 3v5h-7V8z\"><\u002Fpath><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"><\u002Fcircle><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"><\u002Fcircle><\u002Fsvg><\u002Fdiv>\n<div style=\"text-align:center;font-size:20px;font-weight:700\">WindowTime<\u002Fdiv><div class=\"subt\" style=\"text-align:center;margin-bottom:22px\">เข้าสู่ระบบเพื่อใช้งาน<\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">อีเมล<\u002Flabel><input class=\"inp\" placeholder=\"you@company.com\"><\u002Fdiv>\n<div class=\"field\"><label class=\"lbl\">รหัสผ่าน<\u002Flabel><input class=\"inp\" type=\"password\" placeholder=\"••••••••\"><\u002Fdiv>\n<button class=\"pbtn btn-pri\" style=\"margin-top:8px\">เข้าสู่ระบบ<\u002Fbutton>\n<div class=\"authlink\" style=\"margin-top:14px\">ยังไม่มีบัญชี? <a style=\"font-weight:600\">สมัครสมาชิก<\u002Fa><\u002Fdiv>\n<\u002Fdiv><\u002Fdiv><\u002Fdiv><div class=\"mlabel\">หน้าเข้าสู่ระบบ · มือถือ<\u002Fdiv><\u002Fdiv>\n<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fsc-if>\n\n<sc-if value=\"{{ selected }}\" hint-placeholder-val=\"{{ false }}\">\n<div class=\"scrim\" onclick=\"{{ closeDrawer }}\"><div class=\"drawer\" onclick=\"{{ stop }}\">\n<div class=\"dh\"><div class=\"qno\" style=\"width:38px;height:38px;font-size:16px\">{{ selected.q }}<\u002Fdiv><div><div style=\"font-weight:700;font-size:16px\">{{ selected.customer }}<\u002Fdiv><div class=\"subt mono\">{{ selected.order }} · {{ selected.truck }} {{ selected.plate }}<\u002Fdiv><\u002Fdiv><button class=\"dclose\" onclick=\"{{ closeDrawer }}\">✕<\u002Fbutton><\u002Fdiv>\n<div class=\"dbody\">\n<div class=\"metagrid\"><div><div class=\"mlab\">Window Slot<\u002Fdiv><div class=\"mval mono\">{{ selected.window }}<\u002Fdiv><\u002Fdiv><div><div class=\"mlab\">ช่องขึ้นสินค้า<\u002Fdiv><div class=\"mval\">{{ selected.dock }}<\u002Fdiv><\u002Fdiv><div><div class=\"mlab\">คนขับ · ประเภทรถ<\u002Fdiv><div class=\"mval\">{{ selected.driver }} · {{ selected.fleetLabel }}<\u002Fdiv><\u002Fdiv><div><div class=\"mlab\">ปลายทาง<\u002Fdiv><div class=\"mval\">{{ selected.dest }}<\u002Fdiv><\u002Fdiv><\u002Fdiv>\n<sc-if value=\"{{ selected.note }}\" hint-placeholder-val=\"{{ false }}\"><div class=\"note\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" style=\"flex-shrink:0;margin-top:1px\"><circle cx=\"12\" cy=\"12\" r=\"10\"><\u002Fcircle><path d=\"M12 8v4M12 16h.01\"><\u002Fpath><\u002Fsvg><div>{{ selected.note }}<\u002Fdiv><\u002Fdiv><\u002Fsc-if>\n<div class=\"sec\">ไทม์ไลน์การเดินทาง · Journey Timeline<\u002Fdiv>\n<div class=\"tl\"><sc-for list=\"{{ selected.timeline }}\" as=\"s\" hint-placeholder-count=\"7\"><div class=\"step {{ s.cls }}\"><div class=\"stline\"><\u002Fdiv><div class=\"snode\"><sc-if value=\"{{ s.check }}\" hint-placeholder-val=\"{{ false }}\"><svg width=\"11\" height=\"11\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6L9 17l-5-5\"><\u002Fpath><\u002Fsvg><\u002Fsc-if><\u002Fdiv><div><div class=\"slabel\">{{ s.label }}<small>{{ s.en }}<\u002Fsmall><\u002Fdiv><\u002Fdiv><div class=\"stime\"><div class=\"stimev mono {{ s.timeCls }}\">{{ s.time }}<\u002Fdiv><\u002Fdiv><\u002Fdiv><\u002Fsc-for><\u002Fdiv>\n<\u002Fdiv>\n<sc-if value=\"{{ cancelOpen }}\" hint-placeholder-val=\"{{ false }}\"><div class=\"cancelbox\"><div class=\"sec\" style=\"color:#c62b2b;margin:0 0 8px\">สาเหตุที่ลงของไม่สำเร็จ<\u002Fdiv><textarea class=\"inp\" rows=\"3\" oninput=\"{{ setCancelReason }}\" placeholder=\"เช่น สินค้าชำรุด / ลูกค้าปฏิเสธรับ / ปลายทางปิดทำการ\"><\u002Ftextarea><div style=\"display:flex;gap:10px;margin-top:10px\"><button class=\"btn btn-gho\" onclick=\"{{ closeCancel }}\">ย้อนกลับ<\u002Fbutton><button class=\"btn f1\" style=\"background:#c62b2b;color:#fff\" onclick=\"{{ confirmCancel }}\">ยืนยันยกเลิกคิวนี้<\u002Fbutton><\u002Fdiv><\u002Fdiv><\u002Fsc-if>\n<div class=\"dfoot\">\n<sc-if value=\"{{ selected.cancelled }}\" hint-placeholder-val=\"{{ false }}\"><div style=\"flex:1;text-align:center;color:#c62b2b;font-weight:600;font-size:13px;padding:4px\">⚠ คิวนี้ถูกยกเลิก / ลงของไม่สำเร็จ<\u002Fdiv><\u002Fsc-if>\n<sc-if value=\"{{ selected.active }}\" hint-placeholder-val=\"{{ true }}\"><button class=\"btn btn-pri f1\" onclick=\"{{ logNext }}\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"><\u002Fcircle><path d=\"M12 7v5l3 2\"><\u002Fpath><\u002Fsvg>{{ selected.nextLabel }}<\u002Fbutton><button class=\"btn btn-gho\" style=\"color:#c62b2b\" onclick=\"{{ openCancel }}\">⚠ ลงของไม่สำเร็จ<\u002Fbutton><\u002Fsc-if>\n<\u002Fdiv>\n<\u002Fdiv><\u002Fdiv>\n<\u002Fsc-if>\n<\u002Fmain>\n<\u002Fdiv>\n<\u002Fsc-if>\n<sc-if value=\"{{ toast }}\" hint-placeholder-val=\"{{ false }}\"><div class=\"toast\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.6\" stroke-linecap=\"round\"><path d=\"M20 6L9 17l-5-5\"><\u002Fpath><\u002Fsvg>{{ toast }}<\u002Fdiv><\u002Fsc-if>\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;$preview&quot;:{&quot;width&quot;:1440,&quot;height&quot;:900}}\">\nclass Component extends DCLogic {\n  state = {\n    auth:'login', screen:'login', user:null, pg:'dashboard',\n    loginRole:'planner', regRole:'supplier',\n    sec:0, filter:'all', selectedId:null, logged:{}, cancels:{}, cancelOpen:false, cancelReason:'',\n    calDay:8, bookings:[], destList:[], toast:'',\n    form:{email:'demo@company.com',pw:'123456',pw2:'',rname:'',phone:'',date:'2026-07-08',queue:'1',order:'',customer:'',ws:'08:00',dock:'ช่อง 1',fleet:'own',subco:'',truck:'6 ล้อ',plate:'1กน-1234',driver:'สมชาย',dest:''}\n  };\n  componentDidMount(){ this.timer=setInterval(()=>this.setState(s=>({sec:s.sec+1})),1000); }\n  componentWillUnmount(){ clearInterval(this.timer); }\n  nowMin(){ return 13*60+45; }\n  toMin(t){ if(!t) return null; const [h,m]=t.split(':').map(Number); return h*60+m; }\n  fmt(min){ const h=Math.floor(min/60),m=min%60; return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0'); }\n  setF(k,v){ this.setState(s=>({form:{...s.form,[k]:v}})); }\n  flash(msg){ this.setState({toast:msg}); clearTimeout(this._t); this._t=setTimeout(()=>this.setState({toast:''}),2600); }\n\n  roleMeta(r){\n    const m={\n      planner:{name:'ปวีณา สุขใจ',initials:'ปว',roleLabel:'ฝ่ายวางแผน',roleCls:'role-staff',home:'booking'},\n      ops:{name:'ธนพล คลังสินค้า',initials:'ธน',roleLabel:'ฝ่ายปฏิบัติงาน',roleCls:'role-ops',home:'dashboard'},\n      supplier:{name:'Transport A',initials:'TA',roleLabel:'Supplier',roleCls:'role-sup',home:'supplier'},\n      driver:{name:'สมชาย ใจดี',initials:'สม',roleLabel:'คนขับรถ',roleCls:'role-drv',home:'mobile'},\n      exec:{name:'ธีรพงษ์ วัฒน์',initials:'ธร',roleLabel:'ผู้บริหาร',roleCls:'role-exec',home:'kpi'}\n    };\n    return {key:r,...m[r]};\n  }\n\n  data(){\n    return [\n      {q:1,customer:'บจก. ไทยฟู้ดส์ กรุ๊ป',order:'SO-26071',dest:['RDC บางนา'],fleet:'own',plate:'1กน-1234',driver:'สมชาย',truck:'4W',dock:'ท่า 1',win:['08:00','08:30'],st:['07:50','08:05','08:40','08:50','10:30','10:45','11:30'],outcome:'ontime',note:''},\n      {q:2,customer:'บมจ. ซีพี ค้าปลีก',order:'SO-26072',dest:['ศูนย์ฯ ลาดกระบัง'],fleet:'sub',subco:'Transport A',plate:'3กก-5678',driver:'สมศักดิ์',truck:'6W',dock:'ท่า 2',win:['09:00','09:30'],st:['09:15','09:20','10:10','10:20','13:00','13:15',null],outcome:'lateO',note:'สินค้าเปลี่ยนกล่องเกิน 2 พาเลท · ล่าช้าจากต้นทาง'},\n      {q:3,customer:'บจก. เอก-ชัย ดิสทริบิวชั่น',order:'SO-26073',dest:['RDC วังน้อย','สาขา สระบุรี'],fleet:'own',plate:'2กข-9999',driver:'วิชัย',truck:'10W',dock:'ท่า 1',win:['10:00','10:30'],st:['09:45','10:00','10:50','11:00','12:15','12:30','13:15'],outcome:'issue',note:'ลูกค้าคืนสินค้าเปียกฝน · แจ้งฝ่ายคุณภาพแล้ว'},\n      {q:4,customer:'บจก. บิ๊กซี ซัพพลาย',order:'SO-26074',dest:['ศูนย์ฯ สุวรรณภูมิ'],fleet:'sub',subco:'Transport B',plate:'4กง-4321',driver:'มานพ',truck:'4 ล้อ',dock:'ท่า 3',win:['11:00','11:30'],st:['11:45','11:50','12:30','12:40',null,null,null],outcome:'lateO',note:'รับของสายจากต้นทาง 45 นาที · กำลังเดินทางไปปลายทาง'},\n      {q:5,customer:'บจก. เทสโก้ กระจายสินค้า',order:'SO-26075',dest:['RDC บางนา'],fleet:'own',plate:'5กจ-2211',driver:'ประเสริฐ',truck:'6W',dock:'ท่า 4',win:['12:30','13:00'],st:['12:20','12:35','13:20','13:30',null,null,null],outcome:'ontime',note:''},\n      {q:6,customer:'บมจ. สยามแม็คโคร',order:'SO-26076',dest:['ลาดกระบัง','มีนบุรี'],fleet:'sub',subco:'Transport A',plate:'7กฉ-8080',driver:'ธนา',truck:'10W',dock:'ท่า 2',win:['13:30','14:00'],st:['13:35','13:42',null,null,null,null,null],outcome:null,note:''},\n      {q:7,customer:'บจก. ไทยเบฟ โลจิสติกส์',order:'SO-26077',dest:['คลัง วังน้อย'],fleet:'own',plate:'8กช-3131',driver:'วิรัช',truck:'4W',dock:'ท่า 1',win:['14:00','14:30'],st:['13:40',null,null,null,null,null,null],outcome:null,note:''},\n      {q:8,customer:'บจก. โฮมโปร ดีซี',order:'SO-26078',dest:['ศูนย์ฯ สุวรรณภูมิ'],fleet:'sub',subco:'Transport B',plate:'9กซ-4747',driver:'สุริยา',truck:'6W',dock:'ท่า 3',win:['14:30','15:00'],st:[null,null,null,null,null,null,null],outcome:null,note:''},\n      {q:9,customer:'บจก. ดูโฮม ค้าวัสดุ',order:'SO-26079',dest:['สาขา สระบุรี'],fleet:'own',plate:'2กด-5566',driver:'อนุชา',truck:'10W',dock:'ท่า 2',win:['15:30','16:00'],st:[null,null,null,null,null,null,null],outcome:null,note:''},\n      {q:10,customer:'บจก. เซ็นทรัล ฟู้ด',order:'SO-26080',dest:['RDC บางนา'],fleet:'sub',subco:'Transport A',plate:'6กฌ-7788',driver:'ชัยพร',truck:'4W',dock:'ท่า 4',win:['16:00','16:30'],st:[null,null,null,null,null,null,null],outcome:null,note:''}\n    ];\n  }\n  phaseMeta(f){ return [{cls:'ph-sched',label:'รอเข้าคิว',group:'wait'},{cls:'ph-wait',label:'มาถึงแล้ว',group:'active'},{cls:'ph-active',label:'กำลังขึ้นของ',group:'active'},{cls:'ph-wait',label:'ขึ้นของเสร็จ',group:'active'},{cls:'ph-transit',label:'กำลังเดินทาง',group:'active'},{cls:'ph-wait',label:'ถึงปลายทาง',group:'active'},{cls:'ph-active',label:'กำลังลงของ',group:'active'},{cls:'ph-done',label:'เสร็จสิ้น',group:'done'}][f]; }\n  progColor(g){ return g==='done'?'#22b562':g==='issue'?'#e0344b':g==='wait'?'#94a3b8':'#f59e0b'; }\n  tagInfo(o){ return {ontime:['tag-ontime','ตรงเวลา'],lateO:['tag-lateO','เลทต้นทาง'],lateD:['tag-lateD','เลทปลายทาง'],issue:['tag-issue','มีปัญหา']}[o]; }\n  enrich(d){ const m=this.state.logged[d.q]?this.state.logged[d.q]:d.st; let f=0; for(let i=0;i<7;i++){ if(m[i]) f=i+1; } const c=this.state.cancels[d.q]; const outcome=c?'issue':d.outcome; const note=c?('ลงของไม่สำเร็จ: '+c):d.note; const pm=c?{cls:'ph-issue',label:'ยกเลิก',group:'issue'}:this.phaseMeta(f); return {...d,st:m,filled:f,outcome,note,cancelled:!!c,pm,progPct:c?100:Math.round(f/7*100)}; }\n\n  renderVals(){\n    const S=this.state;\n    const showAuth=S.auth!=='app', showApp=S.auth==='app';\n    const total=13*3600+45*60+S.sec; const clock=[Math.floor(total/3600)%24,Math.floor(total/60)%60,total%60].map(x=>String(x).padStart(2,'0')).join(':');\n    const f={}; ['email','pw','pw2','rname','phone','date','queue','order','customer','ws','dock','subco','truck','plate','driver','dest'].forEach(k=>f[k]=e=>this.setF(k,e.target.value));\n    const canPlan=!!(S.user&&S.user.key==='planner'); const canOps=!!(S.user&&(S.user.key==='ops'||S.user.key==='driver'));\n\n    // auth\n    const loginRoles=[['planner','ฝ่ายวางแผน','จัดคิว / กำหนดปลายทาง','📋','background:#e8f0fe'],['ops','ฝ่ายปฏิบัติงาน','บันทึกเวลาทำงาน','🏭','background:#d8f3ee'],['driver','คนขับรถ','เช็คอิน / บันทึกเวลา','🧑‍✈️','background:#fff2dc'],['supplier','Supplier','ดู / จองคิว','🚚','background:#eae7fd'],['exec','ผู้บริหาร','ดูสรุป KPI','📊','background:#e6f6ec']].map(([k,title,sub,emoji,icbg])=>({title,sub,emoji,icbg,cls:S.loginRole===k?'on':'',pick:()=>this.setState({loginRole:k})}));\n    const _oldLoginRoles=[['staff','ทีมคลัง / Logistics','จัดคิว บันทึกเวลา ดู dashboard','🏭','background:#e8f0fe'],['supplier','Supplier','ดูคิว จอง Window','🚚','background:#eae7fd'],['driver','คนขับรถ','เช็คอินหน้างาน','🧑‍✈️','background:#fff2dc'],['exec','ผู้บริหาร','ดูสรุป KPI','📊','background:#e6f6ec']].map(([k,title,sub,emoji,icbg])=>({title,sub,emoji,icbg,cls:S.loginRole===k?'on':'',pick:()=>this.setState({loginRole:k})}));\n    const regRoles=[['supplier','Supplier','🚚','background:#eae7fd'],['driver','คนขับรถ','🧑‍✈️','background:#fff2dc'],['staff','พนักงานคลัง','🏭','background:#e8f0fe']].map(([k,title,emoji,icbg])=>({title,emoji,icbg,cls:S.regRole===k?'on':'',pick:()=>this.setState({regRole:k})}));\n\n    // KPI + dashboard\n    const all=this.data().map(d=>this.enrich(d));\n    const done=all.filter(r=>r.filled===7), active=all.filter(r=>r.filled>0&&r.filled<7);\n    const onTimeN=all.filter(r=>r.outcome==='ontime').length, decided=all.filter(r=>r.outcome&&r.outcome!=='issue').length;\n    const dw=all.filter(r=>r.st[0]&&r.st[3]); const avgDwell=Math.round(dw.reduce((a,r)=>a+(this.toMin(r.st[3])-this.toMin(r.st[0])),0)/dw.length);\n    const delayed=all.filter(r=>['lateO','lateD','issue'].includes(r.outcome)).length;\n    const k={onTime:Math.round(onTimeN/(decided||1)*100),total:all.length,doneCount:done.length,remain:all.length-done.length,active:active.length,delayed,avgDwell};\n    const filters=[['all','ทั้งหมด',all.length],['active','กำลังทำ',active.length],['delayed','ล่าช้า',delayed],['done','เสร็จ',done.length]].map(([key,label,count])=>({key,label,count,cls:S.filter===key?'on':'',set:()=>this.setState({filter:key})}));\n    let list=all; if(S.filter==='active')list=active; else if(S.filter==='done')list=done; else if(S.filter==='delayed')list=all.filter(r=>['lateO','lateD','issue'].includes(r.outcome));\n    const rows=list.map(r=>{const t=this.tagInfo(r.outcome);return {q:r.q,customer:r.customer,order:r.order,dest:r.dest.join(' → '),truck:r.truck,plate:r.plate,driver:r.driver,fleetCls:r.fleet==='own'?'fleet-own':'fleet-sub',fleetLabel:r.fleet==='own'?'Own Fleet':(r.subco||'Sub'),window:r.win[0]+'–'+r.win[1],dock:r.dock,progPct:r.progPct,progStyle:`width:${r.progPct}%;background:${this.progColor(r.pm.group)}`,phCls:r.pm.cls,phLabel:r.pm.label,hasTag:!!t,tagCls:t?t[0]:'',tagLabel:t?t[1]:'',selCls:S.selectedId===r.q?'sel':'',open:()=>this.setState({selectedId:r.q})};});\n    const A=7*60,SPAN=11*60,palette={ontime:'#22b562',lateO:'#e0a020',lateD:'#e0562f',issue:'#e0344b'};\n    const docks=['ท่า 1','ท่า 2','ท่า 3','ท่า 4'].map(name=>({name,slots:all.filter(r=>r.dock===name).map(r=>{const s=this.toMin(r.win[0]),e=this.toMin(r.win[1]);const color=r.outcome?palette[r.outcome]:(r.filled>0?'#5b7cf0':'#aab6cc');return {label:'คิว '+r.q,style:`left:${(s-A)/SPAN*100}%;width:${(e-s)/SPAN*100}%;background:${color}`,open:()=>this.setState({selectedId:r.q})};})}));\n    const ticks=[]; for(let h=7;h<=18;h++) ticks.push(String(h).padStart(2,'0')+':00');\n    const nowStyle=`left:${(this.nowMin()-A)/SPAN*100}%`;\n    const alerts=all.filter(r=>['lateO','lateD','issue'].includes(r.outcome)).map(r=>{const t=this.tagInfo(r.outcome);return {q:r.q,customer:r.customer,tagCls:t[0],tagLabel:t[1],cls:r.outcome==='issue'?'a-issue':r.outcome==='lateD'?'a-lateD':'a-lateO',msg:r.note||'เข้าช้ากว่า Window Slot',open:()=>this.setState({selectedId:r.q})};});\n\n    // drawer\n    let selected=null; const sel=all.find(r=>r.q===S.selectedId);\n    if(sel){ const L=[['เวลามาถึงจริง','Actual Arrive'],['เริ่มขึ้น/ลงสินค้า','Start Load'],['เสร็จสิ้น','Finish Load'],['เวลาที่ออกจริง','Actual Depart'],['เวลาถึงปลายทาง','Arrive Dest'],['เวลาลงสินค้า','Unload Start'],['ออกจากปลายทาง','Depart Dest']];\n      const timeline=L.map((x,i)=>{const t=sel.st[i],d=!!t,nx=!d&&i===sel.filled;return {label:x[0],en:i===0?'Actual Arrive · สแตมป์เมื่อคนขับเช็คอิน':x[1],time:t||'รอบันทึก',timeCls:d?'':'pend',check:d,cls:d?'done':(nx?'next':'')};});\n      const nl=!canOps?'⚠ เฉพาะฝ่ายปฏิบัติงาน/คนขับ':(sel.filled===0?'คนขับเช็คอิน (สแตมป์เวลามาถึง)':(sel.filled<7?('บันทึกเวลา: '+L[sel.filled][0]):'เสร็จครบทุกขั้นแล้ว'));\n      selected={q:sel.q,customer:sel.customer,order:sel.order,truck:sel.truck,plate:sel.plate,driver:sel.driver,window:sel.win[0]+'–'+sel.win[1],dock:sel.dock,fleetLabel:sel.fleet==='own'?'Own Fleet':(sel.subco||'Sub'),dest:sel.dest.join(' → '),note:sel.note,timeline,cancelled:sel.cancelled,active:!sel.cancelled,nextLabel:nl}; }\n\n    // calendar\n    const counts={8:10,7:8,9:6,10:9,6:7,3:5,13:7,14:6,15:8,2:4,16:5,17:6,20:7,21:5};\n    const firstDow=3; const calCells=[];\n    for(let i=0;i<firstDow;i++) calCells.push({day:null,cls:'empty',pick:()=>{}});\n    for(let d=1;d<=31;d++){ const cnt=counts[d]||0; calCells.push({day:d,count:cnt||'',cls:(d===S.calDay?'on ':'')+(d===8?'today':''),pick:()=>this.setState({calDay:d})}); }\n    const thmon=['','ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];\n    const daySel=this.daySchedule(S.calDay,all,counts);\n\n    // booking form\n    const fleetOpts=[['own','Own Fleet (รถบริษัท)'],['sub','Subcontractor (รถ Sub)']].map(([kk,label])=>({label,cls:S.form.fleet===kk?'on':'',pick:()=>this.setF('fleet',kk)}));\n    const dockOpts=[]; for(let i=1;i<=10;i++) dockOpts.push('ช่อง '+i);\n    const truckOpts=['4 ล้อ','6 ล้อ','10 ล้อ'];\n    const plateOpts=['1กน-1234','3กก-5678','2กข-9999','4กง-4321','5กจ-2211','7กฉ-8080','8กช-3131','9กซ-4747','2กด-5566','6กฌ-7788'];\n    const driverOpts=['สมชาย','สมศักดิ์','วิชัย','มานพ','ประเสริฐ','ธนา','วิรัช','สุริยา','อนุชา','ชัยพร'];\n    const destChips=S.destList.map((n,i)=>({name:n,remove:()=>this.setState(s=>({destList:s.destList.filter((_,j)=>j!==i)}))}));\n    const bookings=S.bookings.map(b=>({q:b.q,customer:b.customer,truck:b.truck,dock:b.dock,window:b.window,dest:b.dest}));\n\n    // KPI report\n    const trendVals=[74,69,81,77,72,79,72]; const trendMax=90;\n    const trend=trendVals.map((v,i)=>({v,label:(i+2)+' ก.ค.',style:`height:${v/trendMax*100}%`}));\n    const bd=[['ตรงเวลา','#22b562',78],['เลทต้นทาง','#e0a020',12],['เลทปลายทาง','#e0562f',6],['มีปัญหา','#e0344b',4]];\n    let acc=0; const segs=bd.map(([l,c,v])=>{const s=`${c} ${acc}% ${acc+v}%`;acc+=v;return s;});\n    const donutStyle=`background:conic-gradient(${segs.join(',')})`;\n    const breakdown=bd.map(([label,c,v])=>({label,v,sw:`background:${c}`}));\n    const byCarrier=[['Own Fleet',86,'#22b562'],['Transport C',81,'#3f82f7'],['Transport A',74,'#e0a020'],['Transport B',68,'#e0562f']].map(([name,v,c])=>({name,v,style:`width:${v}%;background:${c}`}));\n\n    // suppliers\n    const suppliers=[\n      {name:'Own Fleet (รถบริษัท)',abbr:'OF',type:'ภายในบริษัท',contact:'ฝ่ายขนส่ง',phone:'02-555-0100',fleetSize:12,trucks:'4W · 6W · 10W',queues:148,ontime:86,issues:9,logobg:'background:linear-gradient(150deg,#1d64f0,#173163)'},\n      {name:'Transport A',abbr:'TA',type:'Subcontractor',contact:'คุณสมศักดิ์',phone:'081-234-5678',fleetSize:8,trucks:'6W · 10W',queues:96,ontime:74,issues:14,logobg:'background:linear-gradient(150deg,#6d5ae0,#4a37c0)'},\n      {name:'Transport B',abbr:'TB',type:'Subcontractor',contact:'คุณมานพ',phone:'089-876-5432',fleetSize:6,trucks:'4 ล้อ · 4W · 6W',queues:61,ontime:68,issues:18,logobg:'background:linear-gradient(150deg,#e0562f,#b23a18)'},\n      {name:'Transport C',abbr:'TC',type:'Subcontractor',contact:'คุณวีระ',phone:'086-345-6789',fleetSize:5,trucks:'6W · 10W',queues:40,ontime:81,issues:6,logobg:'background:linear-gradient(150deg,#0f8a4d,#0a6337)'}\n    ].map(s=>({...s,otColor:s.ontime>=80?'color:#0f8a4d':s.ontime>=72?'color:#b26b06':'color:#c1461c'}));\n\n    // drivers\n    const dstatus={4:['ph-transit','กำลังวิ่ง'],5:['ph-transit','กำลังวิ่ง'],6:['ph-active','กำลังขึ้นของ']};\n    const drivers=this.data().map(d=>{const st=d.filled===7?null:d; const stMeta=dstatus[d.q]?dstatus[d.q]:(d.st[6]?['ph-done','ว่าง']:['ph-sched','เตรียมพร้อม']); const ini=d.driver.slice(0,2); const ot=[92,78,85,71,88,76,94,69,82,90][d.q-1];\n      return {name:d.driver,ini,phone:'08'+(d.q)+'-'+String(1000+d.q*137).slice(0,3)+'-'+String(2000+d.q*211).slice(0,4),plate:d.plate,truck:d.truck,company:d.fleet==='own'?'Own Fleet':d.subco,fleetCls:d.fleet==='own'?'fleet-own':'fleet-sub',trips:d.q<=6?1:0,ontime:ot,otColor:ot>=85?'color:#0f8a4d':ot>=72?'color:#b26b06':'color:#c1461c',stCls:stMeta[0],stLabel:stMeta[1]};});\n\n    // nav + page\n    const pg=S.pg; const nc={}; ['dashboard','calendar','booking','kpi','supplier','driver','mobile'].forEach(p=>nc[p]=pg===p?'on':'');\n    const go={}; ['dashboard','calendar','booking','kpi','supplier','driver','mobile'].forEach(p=>go[p]=()=>this.setState({pg:p,selectedId:null}));\n    const titles={dashboard:['ศูนย์ควบคุมคิวขนส่ง','Dashboard · Live'],calendar:['ปฏิทิน Window','คิวขนส่งรายวัน'],booking:['จอง / จัดคิว','New Booking · Window Slot'],kpi:['รายงาน KPI','Performance Report'],supplier:['Supplier','ผู้ให้บริการขนส่งทั้งหมด'],driver:['คนขับรถ','ทะเบียนคนขับทั้งหมด'],mobile:['มุมมองมือถือ','Mobile Preview']};\n\n    return {\n      showAuth,showApp,isLogin:S.screen==='login',isRegister:S.screen==='register',\n      form:S.form,f,loginRoles,regRoles,\n      goRegister:()=>this.setState({screen:'register'}),goLogin:()=>this.setState({screen:'login'}),\n      doLogin:()=>{const u=this.roleMeta(S.loginRole);this.setState({auth:'app',user:u,pg:u.home});},\n      doRegister:()=>{const m=this.roleMeta(S.regRole);const u={...m,name:S.form.rname||m.name,initials:(S.form.rname||m.name).slice(0,2)};this.setState({auth:'app',user:u,pg:m.home});this.flash('สมัครสมาชิกสำเร็จ · บันทึกลง Google Sheet');},\n      logout:()=>this.setState({auth:'login',screen:'login',user:null}),\n      user:S.user||{},\n      pageTitle:(titles[pg]||['',''])[0],pageSub:(titles[pg]||['',''])[1],\n      pgDash:pg==='dashboard',pgCal:pg==='calendar',pgBook:pg==='booking',pgKpi:pg==='kpi',pgSup:pg==='supplier',pgDrv:pg==='driver',pgMob:pg==='mobile',\n      nc,go,clock,dateLabel:'วันพุธ 8 กรกฎาคม 2569',\n      k,filters,rows,docks,ticks,nowStyle,alerts,selected,\n      calCells,daySel,\n      fleetOpts,isSubFleet:S.form.fleet==='sub',destChips,bookings,noBookings:S.bookings.length===0,\n      dockOpts,truckOpts,plateOpts,driverOpts,\n      canPlan,canOps,noPlanPerm:!canPlan,lockCls:canPlan?'':'locked',\n      cancelOpen:S.cancelOpen,\n      trend,donutStyle,breakdown,byCarrier,suppliers,drivers,toast:S.toast,\n      openCancel:(e)=>{e.stopPropagation();this.setState({cancelOpen:true});},\n      closeCancel:(e)=>{e.stopPropagation();this.setState({cancelOpen:false,cancelReason:''});},\n      setCancelReason:(e)=>this.setState({cancelReason:e.target.value}),\n      confirmCancel:(e)=>{e.stopPropagation(); if(!sel)return; if(!canOps){this.flash('⚠ เฉพาะฝ่ายปฏิบัติงาน/คนขับ');return;} const rsn=(S.cancelReason||'').trim()||'ไม่ระบุสาเหตุ'; this.setState(s=>({cancels:{...s.cancels,[sel.q]:rsn},cancelOpen:false,cancelReason:''})); this.flash('บันทึกการยกเลิก · ซิงก์ Google Sheet');},\n      closeDrawer:()=>this.setState({selectedId:null,cancelOpen:false}),\n      stop:(e)=>e.stopPropagation(),\n      logNext:(e)=>{e.stopPropagation(); if(!sel||sel.filled>=7)return; if(!canOps){this.flash('⚠ เฉพาะฝ่ายปฏิบัติงาน/คนขับที่บันทึกเวลาได้');return;} const cur=(S.logged[sel.q]?[...S.logged[sel.q]]:[...sel.st]); cur[sel.filled]=this.fmt(this.nowMin()); this.setState(s=>({logged:{...s.logged,[sel.q]:cur}})); this.flash(sel.filled===0?'คนขับเช็คอิน · สแตมป์เวลามาถึงแล้ว':'บันทึกเวลาแล้ว · ซิงก์ Google Sheet');},\n      addDest:()=>{const v=S.form.dest.trim(); if(!v)return; this.setState(s=>({destList:[...s.destList,v],form:{...s.form,dest:''}}));},\n      onDestKey:(e)=>{if(e.key==='Enter'){e.preventDefault(); const v=S.form.dest.trim(); if(!v)return; this.setState(s=>({destList:[...s.destList,v],form:{...s.form,dest:''}}));}},\n      submitBooking:()=>{ if(!canPlan){this.flash('⚠ เฉพาะฝ่ายวางแผนเท่านั้นที่จัดคิวได้');return;} const F=S.form; if(!F.customer){this.flash('กรุณากรอกชื่อลูกค้า');return;} const q=F.queue||'-'; const dest=(S.destList.length?S.destList:[F.dest||'-']).join(' → '); const win=F.ws+'–'+this.fmt(this.toMin(F.ws)+30); this.setState(s=>({bookings:[{q,customer:F.customer,truck:F.truck,dock:F.dock,window:win,dest},...s.bookings],destList:[],form:{...s.form,customer:'',order:'',plate:'',driver:'',dest:'',queue:String((parseInt(F.queue)||0)+1)}})); this.flash('จัดคิวสำเร็จ · บันทึกลง Google Sheet');}\n    };\n  }\n\n  daySchedule(day,all,counts){\n    const thd=['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'];\n    const dow=(3+(day-1))%7; const title='วัน'+thd[dow]+' '+day+' ก.ค. 2569';\n    if(day===8){ const items=all.map(r=>({q:r.q,customer:r.customer,dest:r.dest.join(', '),truck:r.truck,window:r.win[0]+'–'+r.win[1],phCls:r.pm.cls,phLabel:r.pm.label})); return {title,count:items.length,items,empty:false}; }\n    const cnt=counts[day]||0; const pool=[['บจก. ไทยฟู้ดส์','RDC บางนา','4W'],['บมจ. ซีพี ค้าปลีก','ลาดกระบัง','6W'],['บจก. เอก-ชัย','วังน้อย','10W'],['บจก. บิ๊กซี','สุวรรณภูมิ','4 ล้อ'],['บจก. เทสโก้','RDC บางนา','6W'],['บมจ. แม็คโคร','มีนบุรี','10W'],['บจก. ไทยเบฟ','วังน้อย','4W'],['บจก. โฮมโปร','สุวรรณภูมิ','6W'],['บจก. ดูโฮม','สระบุรี','10W'],['บจก. เซ็นทรัล','RDC บางนา','4W']];\n    const past=day<8; const items=[]; for(let i=0;i<cnt;i++){ const p=pool[(i+day)%pool.length]; const start=8*60+i*45; items.push({q:i+1,customer:p[0],dest:p[1],truck:p[2],window:this.fmt(start)+'–'+this.fmt(start+30),phCls:past?'ph-done':'ph-sched',phLabel:past?'เสร็จสิ้น':'รอเข้าคิว'}); }\n    return {title,count:cnt,items,empty:cnt===0};\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
</body>
</html>